@using Client_On_Boarding.DTO
@model ClientLeadVM

@{
    ViewData["Title"] = "Client Onboarding";
}

@* ── Page Header ── *@
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-semibold text-gray-800">Client Onboarding</h1>
        <p class="text-sm text-gray-500 mt-0.5">Review and complete client onboarding applications</p>
    </div>
    <a asp-action="CreateOnboarding" asp-controller="Client"
           class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2.5 rounded-lg transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-white" viewBox="0 0 24 24">
            <path d="M18 2c2.206 0 4 1.794 4 4v12c0 2.206-1.794 4-4 4H6c-2.206 0-4-1.794-4-4V6c0-2.206 1.794-4 4-4zm0-2H6a6 6 0 0 0-6 6v12a6 6 0 0 0 6 6h12a6 6 0 0 0 6-6V6a6 6 0 0 0-6-6z" />
            <path d="M12 18a1 1 0 0 1-1-1V7a1 1 0 0 1 2 0v10a1 1 0 0 1-1 1z" />
            <path d="M6 12a1 1 0 0 1 1-1h10a1 1 0 0 1 0 2H7a1 1 0 0 1-1-1z" />
        </svg>
        New Onboarding
    </a>
</div>

@* ── Summary Cards (Onboarding specific) ── *@
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
    <div class="bg-blue-50 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Pending Review</p>
        <p class="text-2xl font-semibold text-gray-800">18</p>
        <span class="inline-block mt-1.5 text-xs font-medium bg-amber-100 text-amber-700 px-2 py-0.5 rounded">Awaiting docs</span>
    </div>
    <div class="bg-blue-50 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">In Progress</p>
        <p class="text-2xl font-semibold text-gray-800">24</p>
        <span class="inline-block mt-1.5 text-xs font-medium bg-blue-100 text-blue-700 px-2 py-0.5 rounded">Verification</span>
    </div>
    <div class="bg-blue-50 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Completed</p>
        <p class="text-2xl font-semibold text-gray-800">63</p>
        <span class="inline-block mt-1.5 text-xs font-medium bg-green-100 text-green-700 px-2 py-0.5 rounded">This quarter</span>
    </div>
    <div class="bg-blue-50 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Avg. Time</p>
        <p class="text-2xl font-semibold text-gray-800">4.2d</p>
        <span class="inline-block mt-1.5 text-xs font-medium bg-purple-100 text-purple-700 px-2 py-0.5 rounded">-1.5d vs last</span>
    </div>
</div>

@* ── Filters & Search ── *@
<div class="bg-white border border-gray-200 rounded-xl mb-4">
    <div class="flex flex-wrap items-center gap-3 px-5 py-3 border-b border-gray-100">
        <div class="flex items-center flex-1 min-w-[200px] bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 gap-2 focus-within:border-blue-400 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192.904 192.904" class="w-4 h-4 fill-gray-400 flex-shrink-0">
                <path d="m190.707 180.101-47.078-47.077c11.702-14.072 18.752-32.142 18.752-51.831C162.381 36.423 125.959 0 81.191 0 36.422 0 0 36.423 0 81.193c0 44.767 36.422 81.187 81.191 81.187 19.688 0 37.759-7.049 51.831-18.751l47.079 47.078a7.474 7.474 0 0 0 5.303 2.197 7.498 7.498 0 0 0 5.303-12.803zM15 81.193C15 44.694 44.693 15 81.191 15c36.497 0 66.189 29.694 66.189 66.193 0 36.496-29.692 66.187-66.189 66.187C44.693 147.38 15 117.689 15 81.193z" />
            </svg>
            <input type="text" placeholder="Search by business name, email or ID..."
                   class="bg-transparent text-sm text-gray-700 outline-none w-full placeholder-gray-400" />
        </div>

        <select class="text-sm bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-gray-700 outline-none focus:border-blue-400 transition-colors">
            <option value="">All Stages</option>
            <option value="pending">Pending Review</option>
            <option value="document">Document Collection</option>
            <option value="verification">Verification</option>
            <option value="approval">Final Approval</option>
            <option value="completed">Completed</option>
            <option value="rejected">Rejected</option>
        </select>

        <select class="text-sm bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-gray-700 outline-none focus:border-blue-400 transition-colors">
            <option value="">All Business Types</option>
            <option value="llc">LLC</option>
            <option value="corporation">Corporation</option>
            <option value="sole">Sole Proprietorship</option>
            <option value="partnership">Partnership</option>
        </select>

        <select class="text-sm bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-gray-700 outline-none focus:border-blue-400 transition-colors">
            <option value="">Sort by: Newest</option>
            <option value="oldest">Sort by: Oldest</option>
            <option value="business">Sort by: Business</option>
            <option value="stage">Sort by: Stage</option>
        </select>
    </div>

    @* ── Onboarding Table ── *@
    <div class="overflow-x-auto">
        <table class="min-w-full">
            <thead class="bg-gray-800 whitespace-nowrap">
                <tr>
                    <th class="p-4 text-left text-xs font-medium text-white">Business / Client</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Contact Info</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Business Type</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Onboarding Stage</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Submitted</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Progress</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Assigned</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Actions</th>
                </tr>
            </thead>
            <tbody class="whitespace-nowrap divide-y divide-gray-100">

                @if (Model.ClientLeads != null && Model.ClientLeads.Any())
                {
                    foreach (var item in Model.ClientLeads)
                    {
                        var companyName = item.CompanyName ?? "-";
                        var ownerName = item.ClientName ?? "-";
                        var email =  "-";
                        var phone = item.PhoneNo ?? "-";
                        var industryName = item.Industry?.IndustryName ?? "-";
                        var statusName = item.LeadStatus?.StatusName ?? "-";
                        
                        var submittedDate = item.CreateDate.HasValue
                             ? item.CreateDate.Value.ToString("dd-MMM-yyyy")
                             : "-";

                        var initials = companyName.Length >= 2
                            ? companyName.Substring(0, 2).ToUpper()
                            : companyName.ToUpper();

                        <tr class="even:bg-blue-50 hover:bg-blue-50 transition-colors">
                            <td class="p-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-semibold flex-shrink-0">
                                        @initials
                                    </div>
                                    <div>
                                        <p class="text-sm font-medium text-gray-800">@companyName</p>
                                        <p class="text-xs text-gray-400">@ownerName</p>
                                    </div>
                                </div>
                            </td>

                            <td class="p-4">
                                <div>
                                    <p class="text-sm text-gray-600">@email</p>
                                    <p class="text-xs text-gray-400">@phone</p>
                                </div>
                            </td>

                            <td class="p-4">
                                <span class="text-xs font-medium bg-purple-100 text-purple-700 px-2.5 py-0.5 rounded-full">
                                    @industryName
                                </span>
                            </td>

                            <td class="p-4">
                                <span class="text-xs font-medium bg-blue-100 text-blue-700 px-2.5 py-0.5 rounded-full">
                                    @statusName
                                </span>
                            </td>

                            <td class="p-4 text-sm text-gray-500">
                                @submittedDate
                            </td>

                            <td class="p-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-20 bg-gray-200 rounded-full h-1.5">
                                        <div class="bg-blue-500 h-1.5 rounded-full w-3/5"></div>
                                    </div>
                                    <span class="text-xs text-gray-500">60%</span>
                                </div>
                            </td>

                            <td class="p-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-6 h-6 rounded-full bg-gray-200 flex items-center justify-center text-xs font-semibold text-gray-600">
                                        AD
                                    </div>
                                    <span class="text-sm text-gray-600">Admin</span>
                                </div>
                            </td>

                            <td class="p-4">
                                <div class="flex items-center gap-2">
                                    <a asp-controller="Client"
                                       asp-action="CreateOnboarding"
                                       asp-route-clientId="@item.Id"
                                       title="Edit Onboarding"
                                       class="text-gray-400 hover:text-blue-600 transition-colors">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 348.882 348.882">
                                            <path d="m333.988 11.758-.42-.383A43.363 43.363 0 0 0 304.258 0a43.579 43.579 0 0 0-32.104 14.153L116.803 184.231a14.993 14.993 0 0 0-3.154 5.37l-18.267 54.762c-2.112 6.331-1.052 13.333 2.835 18.729 3.918 5.438 10.23 8.685 16.886 8.685h.001c2.879 0 5.693-.592 8.362-1.76l52.89-23.138a14.985 14.985 0 0 0 5.063-3.626L336.771 73.176c16.166-17.697 14.919-45.247-2.783-61.418z" />
                                        </svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="p-6 text-center text-sm text-gray-500">
                            No onboarding records found.
                        </td>
                    </tr>
                }

            </tbody>
        </table>
    </div>

    @* ── Pagination ── *@
    <div class="flex flex-wrap items-center justify-between gap-4 px-5 py-4 border-t border-gray-100">
        <p class="text-sm text-gray-500">Showing <span class="font-medium text-gray-700">1–6</span> of <span class="font-medium text-gray-700">105</span> applications</p>
        <div class="flex items-center gap-1">
            <button class="px-3 py-1.5 text-sm text-gray-500 border border-gray-200 rounded-lg hover:bg-gray-50 disabled:opacity-40 transition-colors" disabled>Previous</button>
            <button class="px-3 py-1.5 text-sm bg-blue-600 text-white border border-blue-600 rounded-lg">1</button>
            <button class="px-3 py-1.5 text-sm text-gray-600 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">2</button>
            <button class="px-3 py-1.5 text-sm text-gray-600 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">3</button>
            <span class="px-2 text-gray-400 text-sm">...</span>
            <button class="px-3 py-1.5 text-sm text-gray-600 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">18</button>
            <button class="px-3 py-1.5 text-sm text-gray-600 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">Next</button>
        </div>
    </div>
</div>