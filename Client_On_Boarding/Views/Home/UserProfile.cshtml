@{
    ViewData["Title"] = "My Profile";
}

<div class="p-6 bg-gray-50 min-h-screen">
    
    <!-- Header -->
    <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">My Profile</h1>
            <p class="text-sm text-gray-500 mt-1">Manage your personal information and account settings</p>
        </div>
        <div class="flex items-center gap-3">
            <button onclick="location.reload()" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-600 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Refresh
            </button>
            <button class="inline-flex items-center gap-2 px-5 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Left Column - Profile Card -->
        <div class="lg:col-span-1 space-y-6">
            <!-- Profile Card -->
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="relative h-24 bg-gradient-to-r from-blue-500 to-indigo-600"></div>
                <div class="relative px-6 pb-6">
                    <div class="flex justify-center -mt-12 mb-4">
                        <div class="relative">
                            <img src="https://ui-avatars.com/api/?name=John+Doe&background=3b82f6&color=fff&size=100&rounded=true&bold=true"
                                 alt="Profile" class="w-24 h-24 rounded-full border-4 border-white shadow-lg">
                            <label class="absolute bottom-0 right-0 w-7 h-7 bg-blue-600 rounded-full flex items-center justify-center cursor-pointer hover:bg-blue-700 transition shadow-sm">
                                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                <input type="file" class="hidden" accept="image/*">
                            </label>
                        </div>
                    </div>
                    <div class="text-center">
                        <h2 class="text-xl font-bold text-gray-800">John Doe</h2>
                        <p class="text-sm text-gray-500 mt-0.5">Senior Administrator</p>
                        <div class="flex items-center justify-center gap-2 mt-3">
                            <span class="px-2 py-0.5 text-xs bg-green-100 text-green-700 rounded-full">Active</span>
                            <span class="px-2 py-0.5 text-xs bg-blue-100 text-blue-700 rounded-full">Verified</span>
                        </div>
                    </div>
                    <div class="mt-5 pt-5 border-t border-gray-100">
                        <div class="flex items-center justify-between text-sm">
                            <span class="text-gray-500">Member since</span>
                            <span class="text-gray-800 font-medium">March 2024</span>
                        </div>
                        <div class="flex items-center justify-between text-sm mt-3">
                            <span class="text-gray-500">Last login</span>
                            <span class="text-gray-800 font-medium">Today, 10:30 AM</span>
                        </div>
                        <div class="flex items-center justify-between text-sm mt-3">
                            <span class="text-gray-500">User ID</span>
                            <span class="text-gray-800 font-medium">#USR-001234</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Info Card -->
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
                <h3 class="font-semibold text-gray-800 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    Contact Information
                </h3>
                <div class="space-y-3">
                    <div class="flex items-center gap-3 text-sm">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        <span class="text-gray-600">john.doe@example.com</span>
                    </div>
                    <div class="flex items-center gap-3 text-sm">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                        </svg>
                        <span class="text-gray-600">+1 (555) 123-4567</span>
                    </div>
                    <div class="flex items-center gap-3 text-sm">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <span class="text-gray-600">New York, USA</span>
                    </div>
                </div>
            </div>

            <!-- Role & Permissions -->
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
                <h3 class="font-semibold text-gray-800 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    Role & Permissions
                </h3>
                <div class="space-y-2">
                    <div class="flex items-center justify-between py-2">
                        <span class="text-sm text-gray-600">Administrator Access</span>
                        <span class="text-xs text-green-600 bg-green-100 px-2 py-0.5 rounded-full">Full</span>
                    </div>
                    <div class="flex items-center justify-between py-2 border-t border-gray-100">
                        <span class="text-sm text-gray-600">Client Management</span>
                        <span class="text-xs text-green-600 bg-green-100 px-2 py-0.5 rounded-full">Full</span>
                    </div>
                    <div class="flex items-center justify-between py-2 border-t border-gray-100">
                        <span class="text-sm text-gray-600">Financial Access</span>
                        <span class="text-xs text-amber-600 bg-amber-100 px-2 py-0.5 rounded-full">Read Only</span>
                    </div>
                    <div class="flex items-center justify-between py-2 border-t border-gray-100">
                        <span class="text-sm text-gray-600">System Settings</span>
                        <span class="text-xs text-green-600 bg-green-100 px-2 py-0.5 rounded-full">Full</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column - Edit Form & Tabs -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Tabs -->
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="border-b border-gray-100">
                    <div class="flex">
                        <button class="tab-btn active px-6 py-3 text-sm font-medium text-blue-600 border-b-2 border-blue-600 transition" data-tab="personal">
                            Personal Info
                        </button>
                        <button class="tab-btn px-6 py-3 text-sm font-medium text-gray-500 hover:text-gray-700 transition" data-tab="security">
                            Security
                        </button>
                        <button class="tab-btn px-6 py-3 text-sm font-medium text-gray-500 hover:text-gray-700 transition" data-tab="notifications">
                            Notifications
                        </button>
                        <button class="tab-btn px-6 py-3 text-sm font-medium text-gray-500 hover:text-gray-700 transition" data-tab="activity">
                            Activity
                        </button>
                    </div>
                </div>

                <!-- Tab Content: Personal Info -->
                <div id="tab-personal" class="tab-content p-6">
                    <h3 class="text-lg font-semibold text-gray-800 mb-5">Personal Information</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">First Name <span class="text-red-500">*</span></label>
                            <input type="text" value="John" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:border-blue-400 focus:ring-1 focus:ring-blue-100 outline-none transition">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Last Name <span class="text-red-500">*</span></label>
                            <input type="text" value="Doe" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:border-blue-400 focus:ring-1 focus:ring-blue-100 outline-none transition">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Email Address <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                    </svg>
                                </span>
                                <input type="email" value="john.doe@example.com" class="w-full text-sm border border-gray-200 rounded-lg pl-9 pr-3 py-2.5 focus:border-blue-400 focus:ring-1 focus:ring-blue-100 outline-none transition">
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Phone Number</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                    </svg>
                                </span>
                                <input type="tel" value="+1 (555) 123-4567" class="w-full text-sm border border-gray-200 rounded-lg pl-9 pr-3 py-2.5 focus:border-blue-400 focus:ring-1 focus:ring-blue-100 outline-none transition">
                            </div>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Job Title</label>
                            <input type="text" value="Senior Administrator" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:border-blue-400 focus:ring-1 focus:ring-blue-100 outline-none transition">
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Bio / About</label>
                            <textarea rows="3" placeholder="Tell us about yourself..." class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:border-blue-400 focus:ring-1 focus:ring-blue-100 outline-none transition resize-none">Experienced administrator with over 8 years in client onboarding and ERP management. Passionate about delivering exceptional service and optimizing business processes.</textarea>
                        </div>
                    </div>
                </div>

                <!-- Tab Content: Security -->
                <div id="tab-security" class="tab-content p-6 hidden">
                    <h3 class="text-lg font-semibold text-gray-800 mb-5">Security Settings</h3>
                    <div class="space-y-5">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Current Password</label>
                            <input type="password" placeholder="Enter current password" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:border-blue-400 focus:ring-1 focus:ring-blue-100 outline-none transition">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">New Password</label>
                            <input type="password" placeholder="Enter new password" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:border-blue-400 focus:ring-1 focus:ring-blue-100 outline-none transition">
                            <p class="text-xs text-gray-400 mt-1">Minimum 8 characters with at least one number and special character</p>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Confirm New Password</label>
                            <input type="password" placeholder="Confirm new password" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:border-blue-400 focus:ring-1 focus:ring-blue-100 outline-none transition">
                        </div>
                        <div class="pt-4 border-t border-gray-100">
                            <h4 class="text-sm font-semibold text-gray-700 mb-3">Two-Factor Authentication</h4>
                            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                                <div>
                                    <p class="text-sm font-medium text-gray-700">Enable 2FA</p>
                                    <p class="text-xs text-gray-500">Add an extra layer of security to your account</p>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" class="sr-only peer">
                                    <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tab Content: Notifications -->
                <div id="tab-notifications" class="tab-content p-6 hidden">
                    <h3 class="text-lg font-semibold text-gray-800 mb-5">Notification Preferences</h3>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between p-3 border border-gray-100 rounded-lg hover:bg-gray-50 transition">
                            <div>
                                <p class="text-sm font-medium text-gray-700">Email Notifications</p>
                                <p class="text-xs text-gray-500">Receive updates via email</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" class="sr-only peer" checked>
                                <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                            </label>
                        </div>
                        <div class="flex items-center justify-between p-3 border border-gray-100 rounded-lg hover:bg-gray-50 transition">
                            <div>
                                <p class="text-sm font-medium text-gray-700">Push Notifications</p>
                                <p class="text-xs text-gray-500">Browser push notifications</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" class="sr-only peer" checked>
                                <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                            </label>
                        </div>
                        <div class="flex items-center justify-between p-3 border border-gray-100 rounded-lg hover:bg-gray-50 transition">
                            <div>
                                <p class="text-sm font-medium text-gray-700">New Lead Alerts</p>
                                <p class="text-xs text-gray-500">Get notified when new leads are added</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" class="sr-only peer" checked>
                                <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                            </label>
                        </div>
                        <div class="flex items-center justify-between p-3 border border-gray-100 rounded-lg hover:bg-gray-50 transition">
                            <div>
                                <p class="text-sm font-medium text-gray-700">Payment Received</p>
                                <p class="text-xs text-gray-500">Payment confirmation notifications</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" class="sr-only peer">
                                <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                            </label>
                        </div>
                        <div class="flex items-center justify-between p-3 border border-gray-100 rounded-lg hover:bg-gray-50 transition">
                            <div>
                                <p class="text-sm font-medium text-gray-700">Weekly Digest</p>
                                <p class="text-xs text-gray-500">Weekly summary of activities</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" class="sr-only peer" checked>
                                <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Tab Content: Activity -->
                <div id="tab-activity" class="tab-content p-6 hidden">
                    <h3 class="text-lg font-semibold text-gray-800 mb-5">Recent Activity</h3>
                    <div class="space-y-4">
                        <div class="flex items-start gap-3 pb-4 border-b border-gray-100">
                            <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                            </div>
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-800">New client added</p>
                                <p class="text-xs text-gray-500">You added Ahmed Raza as a new client lead</p>
                                <p class="text-xs text-gray-400 mt-1">2 hours ago</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3 pb-4 border-b border-gray-100">
                            <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-800">Payment received</p>
                                <p class="text-xs text-gray-500">Payment of PKR 50,000 received from Nexova Ltd</p>
                                <p class="text-xs text-gray-400 mt-1">Yesterday, 3:45 PM</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3 pb-4 border-b border-gray-100">
                            <div class="w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                                </svg>
                            </div>
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-800">Invoice overdue</p>
                                <p class="text-xs text-gray-500">Invoice #INV-2026-005 is overdue by 5 days</p>
                                <p class="text-xs text-gray-400 mt-1">Yesterday, 9:00 AM</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
