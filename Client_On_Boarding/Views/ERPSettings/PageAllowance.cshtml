@{
    ViewData["Title"] = "Page Allowances";
}

@* ── Page Header ── *@
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
        <div class="flex items-center gap-2 text-sm text-gray-400 mb-1">
            <a href="javascript:void(0)" class="hover:text-blue-600 transition-colors">Dashboard</a>
            <span>/</span>
            <a href="javascript:void(0)" class="hover:text-blue-600 transition-colors">General Settings</a>
            <span>/</span>
            <span class="text-gray-600">Page Allowances</span>
        </div>
        <h1 class="text-2xl font-semibold text-gray-800">Page Allowances</h1>
        <p class="text-sm text-gray-500 mt-0.5">Configure which ERP pages and modules are accessible for each client tier</p>
    </div>
    <div class="flex items-center gap-3">
        <button type="button" onclick="resetToDefault()"
                class="text-sm text-gray-600 border border-gray-200 rounded-lg px-4 py-2.5 hover:bg-gray-50 transition-colors">
            Reset to Default
        </button>
        <button type="button" onclick="saveAllowances()"
                class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-white" viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
            </svg>
            Save Allowances
        </button>
    </div>
</div>

<form id="pageAllowancesForm" method="post">
    @Html.AntiForgeryToken()

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

        @* ── LEFT COLUMN (Client/Tier Selection) ── *@
        <div class="xl:col-span-1 space-y-6">
            
            @* Client/Tier Selector *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center gap-3 px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="w-7 h-7 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-blue-600" viewBox="0 0 512 512">
                            <path d="M437.02 74.98C388.668 26.63 324.379 0 256 0S123.332 26.629 74.98 74.98C26.63 123.332 0 187.621 0 256s26.629 132.668 74.98 181.02C123.332 485.37 187.621 512 256 512s132.668-26.629 181.02-74.98C485.37 388.668 512 324.379 512 256s-26.629-132.668-74.98-181.02zM111.105 429.297c8.454-72.735 70.989-128.89 144.895-128.89 38.96 0 75.598 15.179 103.156 42.734 23.281 23.285 37.965 53.687 41.742 86.152C361.641 462.172 311.094 482 256 482s-105.637-19.824-144.895-52.703zM256 269.507c-42.871 0-77.754-34.882-77.754-77.753C178.246 148.879 213.13 114 256 114s77.754 34.879 77.754 77.754c0 42.871-34.883 77.754-77.754 77.754z" />
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-700">Select Client / Tier</h2>
                </div>
                <div class="px-5 py-5">
                    <label class="block text-xs font-medium text-gray-600 mb-1.5">Client</label>
                    <select id="clientSelect" name="ClientId" onchange="loadClientAllowances()"
                            class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all mb-4">
                        <option value="">Select a client</option>
                        <option value="1">Nexova Ltd (Ahmed Raza)</option>
                        <option value="2">Apexion Inc. (David Osei)</option>
                        <option value="3">Cloudform Pvt. (Priya Nair)</option>
                        <option value="4">DataSpark GmbH (Lena Müller)</option>
                        <option value="5">Brightline Co. (Sara Malik)</option>
                    </select>
                    
                    <label class="block text-xs font-medium text-gray-600 mb-1.5">Or Select Tier Template</label>
                    <select id="tierSelect" name="TierId" onchange="loadTierAllowances()"
                            class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all">
                        <option value="">Select a tier template</option>
                        <option value="basic">Basic Plan</option>
                        <option value="professional">Professional Plan</option>
                        <option value="enterprise">Enterprise Plan</option>
                        <option value="custom">Custom Configuration</option>
                    </select>
                </div>
            </div>

            @* Summary Card *@
            <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-100 rounded-xl p-5">
                <div class="flex items-center justify-between mb-3">
                    <p class="text-xs font-semibold text-blue-700 uppercase tracking-wide">Allowance Summary</p>
                    <span id="pageCount" class="text-2xl font-bold text-blue-700">0</span>
                </div>
                <p class="text-sm text-gray-600">pages selected</p>
                <div class="mt-3 pt-3 border-t border-blue-100">
                    <div class="flex justify-between text-xs text-gray-500 mb-1">
                        <span>Storage Used</span>
                        <span id="storageUsed">0 MB</span>
                    </div>
                    <div class="w-full bg-blue-200 rounded-full h-1.5">
                        <div id="storageBar" class="bg-blue-600 h-1.5 rounded-full" style="width: 0%"></div>
                    </div>
                </div>
            </div>

            @* Quick Actions *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <h2 class="text-sm font-semibold text-gray-700">Quick Actions</h2>
                </div>
                <div class="px-5 py-4 space-y-2">
                    <button type="button" onclick="selectAllPages()" class="w-full text-left text-sm text-gray-600 hover:text-blue-600 py-2 px-3 rounded-lg hover:bg-blue-50 transition-colors flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14H7v-2h3v2zm0-4H7v-2h3v2zm0-4H7V7h3v2zm6 8h-3v-2h3v2zm0-4h-3v-2h3v2zm0-4h-3V7h3v2z" /></svg>
                        Select All Pages
                    </button>
                    <button type="button" onclick="deselectAllPages()" class="w-full text-left text-sm text-gray-600 hover:text-red-600 py-2 px-3 rounded-lg hover:bg-red-50 transition-colors flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14H7v-2h3v2zm0-4H7v-2h3v2zm0-4H7V7h3v2z" /></svg>
                        Deselect All Pages
                    </button>
                    <button type="button" onclick="loadBasicPlan()" class="w-full text-left text-sm text-gray-600 hover:text-blue-600 py-2 px-3 rounded-lg hover:bg-blue-50 transition-colors flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15h-2v-2h2v2zm0-4h-2V7h2v6z" /></svg>
                        Apply Basic Plan
                    </button>
                    <button type="button" onclick="loadProfessionalPlan()" class="w-full text-left text-sm text-gray-600 hover:text-blue-600 py-2 px-3 rounded-lg hover:bg-blue-50 transition-colors flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15h-2v-2h2v2zm0-4h-2V7h2v6z" /></svg>
                        Apply Professional Plan
                    </button>
                    <button type="button" onclick="loadEnterprisePlan()" class="w-full text-left text-sm text-gray-600 hover:text-blue-600 py-2 px-3 rounded-lg hover:bg-blue-50 transition-colors flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15h-2v-2h2v2zm0-4h-2V7h2v6z" /></svg>
                        Apply Enterprise Plan
                    </button>
                </div>
            </div>
        </div>

        @* ── RIGHT COLUMN (Page Allowances Grid) ── *@
        <div class="xl:col-span-2 space-y-6">

            @* Dashboard & Analytics Section *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="flex items-center gap-3">
                        <div class="w-7 h-7 rounded-lg bg-indigo-100 flex items-center justify-center flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-indigo-600" viewBox="0 0 24 24">
                                <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" />
                            </svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-700">Dashboard & Analytics</h2>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-gray-400">Select all</span>
                        <input type="checkbox" id="selectAllDashboard" onchange="toggleSection('dashboard', this.checked)" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                    </div>
                </div>
                <div class="px-5 py-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="dashboard_overview" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="dashboard" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Dashboard Overview</p>
                                <p class="text-xs text-gray-400">Main dashboard with KPIs</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="analytics_reports" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="dashboard" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Analytics Reports</p>
                                <p class="text-xs text-gray-400">Advanced analytics and insights</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="custom_reports" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="dashboard" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Custom Reports</p>
                                <p class="text-xs text-gray-400">Build custom report builder</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            @* Sales & CRM Section *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="flex items-center gap-3">
                        <div class="w-7 h-7 rounded-lg bg-green-100 flex items-center justify-center flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-green-600" viewBox="0 0 24 24">
                                <path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z" />
                            </svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-700">Sales & CRM</h2>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-gray-400">Select all</span>
                        <input type="checkbox" id="selectAllSales" onchange="toggleSection('sales', this.checked)" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                    </div>
                </div>
                <div class="px-5 py-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="leads_management" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="sales" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Leads Management</p>
                                <p class="text-xs text-gray-400">Track and manage client leads</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="opportunities" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="sales" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Opportunities</p>
                                <p class="text-xs text-gray-400">Sales pipeline management</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="quotations" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="sales" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Quotations</p>
                                <p class="text-xs text-gray-400">Create and send quotes</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="invoices" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="sales" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Invoices</p>
                                <p class="text-xs text-gray-400">Invoice management</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="payments" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="sales" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Payments</p>
                                <p class="text-xs text-gray-400">Payment tracking</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="contracts" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="sales" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Contracts</p>
                                <p class="text-xs text-gray-400">Contract management</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            @* Inventory & Products Section *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="flex items-center gap-3">
                        <div class="w-7 h-7 rounded-lg bg-amber-100 flex items-center justify-center flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-amber-600" viewBox="0 0 24 24">
                                <path d="M20 6h-4V4c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zM10 4h4v2h-4V4z" />
                            </svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-700">Inventory & Products</h2>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-gray-400">Select all</span>
                        <input type="checkbox" id="selectAllInventory" onchange="toggleSection('inventory', this.checked)" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                    </div>
                </div>
                <div class="px-5 py-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="products" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="inventory" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Products</p>
                                <p class="text-xs text-gray-400">Product catalog management</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="stock_management" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="inventory" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Stock Management</p>
                                <p class="text-xs text-gray-400">Inventory tracking</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="purchase_orders" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="inventory" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Purchase Orders</p>
                                <p class="text-xs text-gray-400">Manage supplier orders</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="suppliers" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="inventory" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Suppliers</p>
                                <p class="text-xs text-gray-400">Vendor management</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="warehouse" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="inventory" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Warehouse</p>
                                <p class="text-xs text-gray-400">Multi-warehouse management</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            @* HR & Employees Section *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="flex items-center gap-3">
                        <div class="w-7 h-7 rounded-lg bg-purple-100 flex items-center justify-center flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-purple-600" viewBox="0 0 24 24">
                                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                            </svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-700">HR & Employees</h2>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-gray-400">Select all</span>
                        <input type="checkbox" id="selectAllHr" onchange="toggleSection('hr', this.checked)" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                    </div>
                </div>
                <div class="px-5 py-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="employees" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="hr" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Employees</p>
                                <p class="text-xs text-gray-400">Employee directory</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="attendance" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="hr" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Attendance</p>
                                <p class="text-xs text-gray-400">Time tracking</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="payroll" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="hr" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Payroll</p>
                                <p class="text-xs text-gray-400">Salary management</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="leaves" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="hr" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Leaves</p>
                                <p class="text-xs text-gray-400">Leave requests</p>
                            </div>
                        </label>
                        <label class="allowance-item flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                            <input type="checkbox" name="PageAllowances" value="recruitment" class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" data-section="hr" />
                            <div>
                                <p class="text-sm font-medium text-gray-700">Recruitment</p>
                                <p class="text-xs text-gray-400">Job postings & candidates</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            @* Finance & Accounting Section *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="flex items-center gap-3">
                        <div class="w-7 h-7 rounded-lg bg-red-100 flex items-center justify-center flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-red-600" viewBox="0 0 24 24">
