@{
    ViewData["Title"] = "Customer Receipt";
}

@* ── Page Header ── *@
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
        <div class="flex items-center gap-2 text-sm text-gray-400 mb-1">
            <a href="javascript:void(0)" class="hover:text-blue-600 transition-colors">Dashboard</a>
            <span>/</span>
            <a href="javascript:void(0)" class="hover:text-blue-600 transition-colors">Sales</a>
            <span>/</span>
            <span class="text-gray-600">Customer Receipt</span>
        </div>
        <h1 class="text-2xl font-semibold text-gray-800">Customer Receipt</h1>
        <p class="text-sm text-gray-500 mt-0.5">Record and manage customer payments</p>
    </div>
    <div class="flex items-center gap-3">
        <a href="javascript:void(0)"
               class="text-sm text-gray-600 border border-gray-200 rounded-lg px-4 py-2.5 hover:bg-gray-50 transition-colors">
            Cancel
        </a>
        <button type="submit" form="receiptForm"
                class="flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-white" viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
            </svg>
            Process Payment
        </button>
    </div>
</div>

<form id="receiptForm" method="post" autocomplete="off">
    @Html.AntiForgeryToken()

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

        @* ── LEFT COLUMN (Payment Details) ── *@
        <div class="xl:col-span-2 space-y-6">

            @* Customer Information *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="w-7 h-7 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-blue-600" viewBox="0 0 512 512">
                            <path d="M437.02 74.98C388.668 26.63 324.379 0 256 0S123.332 26.629 74.98 74.98C26.63 123.332 0 187.621 0 256s26.629 132.668 74.98 181.02C123.332 485.37 187.621 512 256 512s132.668-26.629 181.02-74.98C485.37 388.668 512 324.379 512 256s-26.629-132.668-74.98-181.02zM111.105 429.297c8.454-72.735 70.989-128.89 144.895-128.89 38.96 0 75.598 15.179 103.156 42.734 23.281 23.285 37.965 53.687 41.742 86.152C361.641 462.172 311.094 482 256 482s-105.637-19.824-144.895-52.703zM256 269.507c-42.871 0-77.754-34.882-77.754-77.753C178.246 148.879 213.13 114 256 114s77.754 34.879 77.754 77.754c0 42.871-34.883 77.754-77.754 77.754z" />
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-700">Customer Information</h2>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Select Customer <span class="text-red-500">*</span></label>
                            <select name="CustomerId" id="CustomerId" onchange="loadCustomerDetails()" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all">
                                <option value="">-- Search or select customer --</option>
                                <option value="1">Ahmed Raza - Nexova Ltd</option>
                                <option value="2">Sara Malik - Brightline Co.</option>
                                <option value="3">David Osei - Apexion Inc.</option>
                                <option value="4">Priya Nair - Cloudform Pvt.</option>
                                <option value="5">Tom Barker - Steelwerk Ltd</option>
                                <option value="6">Lena Müller - DataSpark GmbH</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Customer Email</label>
                            <input type="email" id="CustomerEmail" readonly
                                   class="w-full text-sm bg-gray-50 border border-gray-200 rounded-lg px-3 py-2.5 outline-none text-gray-600" />
                        </div>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Customer Phone</label>
                            <input type="text" id="CustomerPhone" readonly
                                   class="w-full text-sm bg-gray-50 border border-gray-200 rounded-lg px-3 py-2.5 outline-none text-gray-600" />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Outstanding Balance</label>
                            <input type="text" id="OutstandingBalance" readonly
                                   class="w-full text-sm bg-red-50 border border-red-200 rounded-lg px-3 py-2.5 outline-none text-red-700 font-semibold" />
                        </div>
                    </div>
                </div>
            </div>

            @* Invoice Selection *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="w-7 h-7 rounded-lg bg-purple-100 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-purple-600" viewBox="0 0 24 24">
                            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14H7v-2h3v2zm0-4H7v-2h3v2zm0-4H7V7h3v2zm6 8h-3v-2h3v2zm0-4h-3v-2h3v2zm0-4h-3V7h3v2z" />
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-700">Select Invoices to Pay</h2>
                </div>
                <div class="px-6 py-5">
                    <div class="overflow-x-auto">
                        <table class="min-w-full">
                            <thead class="bg-gray-100">
                                <tr>
                                    <th class="p-3 text-left text-xs font-medium text-gray-600 w-10">
                                        <input type="checkbox" id="selectAllInvoices" onchange="toggleAllInvoices()" class="rounded border-gray-300 text-blue-600" />
                                    </th>
                                    <th class="p-3 text-left text-xs font-medium text-gray-600">Invoice #</th>
                                    <th class="p-3 text-left text-xs font-medium text-gray-600">Date</th>
                                    <th class="p-3 text-left text-xs font-medium text-gray-600">Due Date</th>
                                    <th class="p-3 text-right text-xs font-medium text-gray-600">Invoice Amount</th>
                                    <th class="p-3 text-right text-xs font-medium text-gray-600">Due Amount</th>
                                    <th class="p-3 text-right text-xs font-medium text-gray-600">Paying Amount</th>
                                </tr>
                            </thead>
                            <tbody id="invoicesList" class="divide-y divide-gray-100">
                                <tr class="text-center text-gray-400">
                                    <td colspan="7" class="p-6">Select a customer to view invoices</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @* Payment Details *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="w-7 h-7 rounded-lg bg-green-100 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-green-600" viewBox="0 0 24 24">
                            <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-4h16v4z" />
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-700">Payment Details</h2>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Payment Date <span class="text-red-500">*</span></label>
                            <input type="date" name="PaymentDate" value="@DateTime.Now.ToString("yyyy-MM-dd")"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all" />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Payment Method <span class="text-red-500">*</span></label>
                            <select name="PaymentMethod" id="PaymentMethod" onchange="toggleChequeFields()" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all">
                                <option value="">Select payment method</option>
                                <option value="cash">Cash</option>
                                <option value="bank_transfer">Bank Transfer</option>
                                <option value="cheque">Cheque</option>
                                <option value="credit_card">Credit Card</option>
                                <option value="online">Online Payment Gateway</option>
                            </select>
                        </div>
                    </div>

                    <div id="chequeFields" class="hidden grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Cheque Number</label>
                            <input type="text" name="ChequeNumber" placeholder="e.g. 123456" autocomplete="off"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all" />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Cheque Date</label>
                            <input type="date" name="ChequeDate"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all" />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Bank Name</label>
                            <input type="text" name="BankName" placeholder="e.g. HBL, UBL" autocomplete="off"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all" />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Transaction / Reference ID</label>
                            <input type="text" name="TransactionId" placeholder="Optional reference number" autocomplete="off"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all" />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Attachment (Receipt)</label>
                            <input type="file" name="Attachment" accept=".pdf,.jpg,.png"
                                   class="w-full text-sm text-gray-500 file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1.5">Notes / Remarks</label>
                        <textarea name="Notes" rows="2" placeholder="Any additional notes about this payment..." autocomplete="off"
                                  class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all resize-none placeholder-gray-400"></textarea>
                    </div>
                </div>
            </div>
        </div>

        @* ── RIGHT COLUMN (Payment Summary) ── *@
        <div class="space-y-6">

            @* Payment Summary Card *@
            <div class="bg-gradient-to-r from-blue-600 to-blue-700 rounded-xl overflow-hidden shadow-lg sticky top-24">
                <div class="px-5 py-4 border-b border-blue-500">
                    <h2 class="text-sm font-semibold text-white">Payment Summary</h2>
                </div>
                <div class="px-5 py-5 space-y-3">
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-blue-100">Total Selected Invoices:</span>
                        <span id="selectedCount" class="text-lg font-bold text-white">0</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-blue-100">Total Invoice Amount:</span>
                        <span id="totalInvoiceAmount" class="text-lg font-bold text-white">PKR 0.00</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-blue-100">Total Due Amount:</span>
                        <span id="totalDueAmount" class="text-lg font-bold text-white">PKR 0.00</span>
                    </div>
                    <div class="border-t border-blue-500 my-2"></div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-semibold text-white">Amount to Pay:</span>
                        <span id="totalPayingAmount" class="text-2xl font-bold text-white">PKR 0.00</span>
                    </div>
                    <div class="mt-4">
                        <div class="relative">
                            <label class="block text-xs font-medium text-blue-200 mb-1.5">Or enter custom amount</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-gray-500 text-sm">PKR</span>
                                <input type="number" id="CustomAmount" name="CustomAmount" placeholder="0.00" step="0.01"
                                       onchange="updateCustomAmount()"
                                       class="w-full text-sm border border-blue-300 rounded-lg pl-12 pr-3 py-2.5 outline-none focus:border-white bg-blue-500 text-white placeholder-blue-200" />
                            </div>
                        </div>
                        <p class="text-xs text-blue-200 mt-1.5">Leave empty to pay full due amount</p>
                    </div>
                </div>
            </div>

            @* Payment Confirmation *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <h2 class="text-sm font-semibold text-gray-700">Payment Confirmation</h2>
                </div>
                <div class="px-5 py-4 space-y-3">
                    <label class="flex items-start gap-3 cursor-pointer">
                        <input type="checkbox" id="ConfirmPayment" name="ConfirmPayment" class="mt-0.5 rounded border-gray-300 text-green-600 focus:ring-green-500" />
                        <div>
                            <p class="text-sm text-gray-700 font-medium">I confirm that the payment has been received</p>
                            <p class="text-xs text-gray-400">This will mark the selected invoices as paid</p>
                        </div>
                    </label>
                    <label class="flex items-start gap-3 cursor-pointer">
                        <input type="checkbox" id="SendReceipt" name="SendReceipt" class="mt-0.5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" checked />
                        <div>
                            <p class="text-sm text-gray-700 font-medium">Send receipt to customer via email</p>
                            <p class="text-xs text-gray-400">Customer will receive payment confirmation</p>
                        </div>
                    </label>
                </div>
            </div>

            @* Recent Payments *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <h2 class="text-sm font-semibold text-gray-700">Recent Payments</h2>
                </div>
                <div class="px-5 py-3 space-y-2 max-h-64 overflow-y-auto">
                    <div class="flex justify-between items-center py-2 border-b border-gray-100">
                        <div>
                            <p class="text-xs font-medium text-gray-700">INV-2026-001</p>
                            <p class="text-xs text-gray-400">15 Mar 2026</p>
                        </div>
                        <div class="text-right">
                            <p class="text-xs font-semibold text-green-600">PKR 25,000</p>
                            <p class="text-xs text-gray-400">Bank Transfer</p>
                        </div>
                    </div>
                    <div class="flex justify-between items-center py-2 border-b border-gray-100">
                        <div>
                            <p class="text-xs font-medium text-gray-700">INV-2026-002</p>
                            <p class="text-xs text-gray-400">10 Mar 2026</p>
                        </div>
                        <div class="text-right">
                            <p class="text-xs font-semibold text-green-600">PKR 50,000</p>
                            <p class="text-xs text-gray-400">Cheque</p>
                        </div>
                    </div>
                    <div class="flex justify-between items-center py-2">
                        <div>
                            <p class="text-xs font-medium text-gray-700">INV-2026-003</p>
                            <p class="text-xs text-gray-400">01 Mar 2026</p>
                        </div>
                        <div class="text-right">
                            <p class="text-xs font-semibold text-green-600">PKR 12,500</p>
                            <p class="text-xs text-gray-400">Cash</p>
                        </div>
                    </div>
                </div>
            </div>

            @* Mobile Action Buttons *@
            <div class="bg-white border border-gray-200 rounded-xl px-5 py-4 flex gap-3 xl:hidden">
                <a href="javascript:void(0)"
                       class="flex-1 text-center text-sm text-gray-600 border border-gray-200 rounded-lg px-4 py-2.5 hover:bg-gray-50 transition-colors">
                    Cancel
                </a>
                <button type="submit" form="receiptForm"
                        class="flex-1 flex items-center justify-center gap-2 bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-4 py-2.5 rounded-lg transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-white" viewBox="0 0 24 24">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                    </svg>
                    Process Payment
                </button>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    <script>
        // Sample invoice data
        const invoiceData = {
            1: [ // Ahmed Raza - Nexova Ltd
                { id: 1, number: 'INV-2026-001', date: '2026-03-01', dueDate: '2026-03-31', amount: 50000, dueAmount: 25000 },
                { id: 2, number: 'INV-2026-005', date: '2026-03-15', dueDate: '2026-04-14', amount: 35000, dueAmount: 35000 },
                { id: 3, number: 'INV-2026-008', date: '2026-03-20', dueDate: '2026-04-19', amount: 28000, dueAmount: 28000 }
            ],
            2: [ // Sara Malik - Brightline Co.
                { id: 4, number: 'INV-2026-002', date: '2026-03-05', dueDate: '2026-04-04', amount: 75000, dueAmount: 75000 },
                { id: 5, number: 'INV-2026-006', date: '2026-03-18', dueDate: '2026-04-17', amount: 45000, dueAmount: 15000 }
            ],
            3: [ // David Osei - Apexion Inc.
                { id: 6, number: 'INV-2026-003', date: '2026-02-28', dueDate: '2026-03-30', amount: 120000, dueAmount: 0 },
                { id: 7, number: 'INV-2026-009', date: '2026-03-22', dueDate: '2026-04-21', amount: 65000, dueAmount: 65000 }
            ],
            4: [ // Priya Nair - Cloudform Pvt.
                { id: 8, number: 'INV-2026-004', date: '2026-03-10', dueDate: '2026-04-09', amount: 95000, dueAmount: 95000 }
            ],
            5: [ // Tom Barker - Steelwerk Ltd
                { id: 9, number: 'INV-2026-007', date: '2026-03-12', dueDate: '2026-04-11', amount: 180000, dueAmount: 80000 }
            ],
            6: [ // Lena Müller - DataSpark GmbH
                { id: 10, number: 'INV-2026-010', date: '2026-03-25', dueDate: '2026-04-24', amount: 42000, dueAmount: 42000 }
            ]
        };

        const customerDetails = {
            1: { name: 'Ahmed Raza', email: 'ahmed.raza@nexova.com', phone: '+92 300 1234567', balance: 88000 },
            2: { name: 'Sara Malik', email: 'sara@brightline.com', phone: '+92 321 9876543', balance: 90000 },
            3: { name: 'David Osei', email: 'david@apexion.com', phone: '+1 415 5550172', balance: 65000 },
            4: { name: 'Priya Nair', email: 'priya@cloudform.com', phone: '+91 98765 43210', balance: 95000 },
            5: { name: 'Tom Barker', email: 'tom@steelwerk.co.uk', phone: '+44 7911 123456', balance: 80000 },
            6: { name: 'Lena Müller', email: 'lena@dataspark.de', phone: '+49 160 9876543', balance: 42000 }
        };

        let selectedInvoices = {};

        function loadCustomerDetails() {
            const customerId = document.getElementById('CustomerId').value;
            if (customerId && customerDetails[customerId]) {
                const details = customerDetails[customerId];
                document.getElementById('CustomerEmail').value = details.email;
                document.getElementById('CustomerPhone').value = details.phone;
                document.getElementById('OutstandingBalance').value = 'PKR ' + details.balance.toLocaleString();
                loadInvoices(customerId);
            } else {
                document.getElementById('CustomerEmail').value = '';
                document.getElementById('CustomerPhone').value = '';
                document.getElementById('OutstandingBalance').value = '';
                document.getElementById('invoicesList').innerHTML = '<tr class="text-center text-gray-400"><td colspan="7" class="p-6">Select a customer to view invoices</td></tr>';
                resetSummary();
            }
        }

        function loadInvoices(customerId) {
            const invoices = invoiceData[customerId] || [];
            const tbody = document.getElementById('invoicesList');
        
            if (invoices.length === 0) {
                tbody.innerHTML = '<tr class="text-center text-gray-400"><td colspan="7" class="p-6">No pending invoices for this customer</td></tr>';
                return;
            }

            tbody.innerHTML = invoices.map(inv => `
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="p-3">
                        <input type="checkbox" name="SelectedInvoices" value="${inv.id}" data-amount="${inv.dueAmount}" onchange="updateInvoiceAmount(this, ${inv.id}, ${inv.dueAmount})" class="invoice-checkbox rounded border-gray-300 text-blue-600" />
                    </td>
                    <td class="p-3 text-sm text-gray-700">${inv.number}</td>
                    <td class="p-3 text-sm text-gray-500">${inv.date}</td>
                    <td class="p-3 text-sm text-gray-500">${inv.dueDate}</td>
                    <td class="p-3 text-right text-sm text-gray-700">PKR ${inv.amount.toLocaleString()}</td>
                    <td class="p-3 text-right text-sm font-medium ${inv.dueAmount > 0 ? 'text-red-600' : 'text-green-600'}">PKR ${inv.dueAmount.toLocaleString()}</td>
                    <td class="p-3 text-right">
                        <input type="number" id="paying_${inv.id}" placeholder="Amount" step="0.01" max="${inv.dueAmount}" value="${inv.dueAmount}" onchange="updatePayingAmount(${inv.id}, ${inv.dueAmount})" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1.5 text-right outline-none focus:border-blue-400" />
                    </td>
                </tr>
            `).join('');
        
            selectedInvoices = {};
            resetSummary();
        }

        function toggleAllInvoices() {
            const selectAll = document.getElementById('selectAllInvoices');
            const checkboxes = document.querySelectorAll('.invoice-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = selectAll.checked;
                const invoiceId = parseInt(cb.value);
                const dueAmount = parseFloat(cb.dataset.amount);
                if (selectAll.checked) {
                    selectedInvoices[invoiceId] = dueAmount;
                    const payingInput = document.getElementById(`paying_${invoiceId}`);
                    if (payingInput) payingInput.value = dueAmount;
                } else {
                    delete selectedInvoices[invoiceId];
                    const payingInput = document.getElementById(`paying_${invoiceId}`);
                    if (payingInput) payingInput.value = '';
                }
            });
            updateSummary();
        }

        function updateInvoiceAmount(checkbox, invoiceId, dueAmount) {
            if (checkbox.checked) {
                selectedInvoices[invoiceId] = dueAmount;
                const payingInput = document.getElementById(`paying_${invoiceId}`);
                if (payingInput) payingInput.value = dueAmount;
            } else {
                delete selectedInvoices[invoiceId];
                const payingInput = document.getElementById(`paying_${invoiceId}`);
                if (payingInput) payingInput.value = '';
            }
            updateSummary();
        }

        function updatePayingAmount(invoiceId, dueAmount) {
            const payingInput = document.getElementById(`paying_${invoiceId}`);
            let amount = parseFloat(payingInput.value);
            if (isNaN(amount) || amount < 0) amount = 0;
            if (amount > dueAmount) amount = dueAmount;
            payingInput.value = amount;
        
            if (amount > 0) {
                selectedInvoices[invoiceId] = amount;
                const checkbox = document.querySelector(`.invoice-checkbox[value="${invoiceId}"]`);
                if (checkbox && !checkbox.checked) checkbox.checked = true;
            } else {
                delete selectedInvoices[invoiceId];
                const checkbox = document.querySelector(`.invoice-checkbox[value="${invoiceId}"]`);
                if (checkbox) checkbox.checked = false;
            }
            updateSummary();
        }

        function updateSummary() {
            const selectedCount = Object.keys(selectedInvoices).length;
            let totalPaying = 0;
        
            for (const amount of Object.values(selectedInvoices)) {
                totalPaying += amount;
            }
        
            document.getElementById('selectedCount').innerText = selectedCount;
            document.getElementById('totalPayingAmount').innerHTML = 'PKR ' + totalPaying.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        
            // Clear custom amount when invoices are selected/deselected
            const customAmount = document.getElementById('CustomAmount');
            if (customAmount) customAmount.value = '';
        }

        function updateCustomAmount() {
            const customAmount = parseFloat(document.getElementById('CustomAmount').value);
            if (!isNaN(customAmount) && customAmount > 0) {
                document.getElementById('totalPayingAmount').innerHTML = 'PKR ' + customAmount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            } else {
                updateSummary();
            }
        }

        function resetSummary() {
            document.getElementById('selectedCount').innerText = '0';
            document.getElementById('totalPayingAmount').innerHTML = 'PKR 0.00';
            document.getElementById('CustomAmount').value = '';
        }

        function toggleChequeFields() {
            const paymentMethod = document.getElementById('PaymentMethod').value;
            const chequeFields = document.getElementById('chequeFields');
            if (paymentMethod === 'cheque') {
                chequeFields.classList.remove('hidden');
            } else {
                chequeFields.classList.add('hidden');
            }
        }

        // Initialize
        document.getElementById('selectAllInvoices').checked = false;
    </script>
}