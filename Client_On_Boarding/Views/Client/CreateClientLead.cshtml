@using Client_On_Boarding.DTO
@model ClientLeadVM

@{
    ViewData["Title"] = "Add Client";
}

@* ── Validation Summary ── *@
@if (!ViewData.ModelState.IsValid)
{
    <div class="mb-5 flex items-start gap-3 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-xl">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-red-500 flex-shrink-0 mt-0.5" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
        </svg>
        <div>
            <p class="font-medium mb-1">Please fix the following errors:</p>
            <asp-validation-summary model-only="true" class="list-disc list-inside space-y-0.5 text-xs" />
        </div>
    </div>
}

@* ── Page Header ── *@
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
        <div class="flex items-center gap-2 text-sm text-gray-400 mb-1">
            <a asp-action="Index" asp-controller="Home" class="hover:text-blue-600 transition-colors">Dashboard</a>
            <span>/</span>
            <a asp-action="ClientLeads" asp-controller="Client" class="hover:text-blue-600 transition-colors">Client Leads</a>
            <span>/</span>
            <span class="text-gray-600">Add Client</span>
        </div>
        <h1 class="text-2xl font-semibold text-gray-800">Add New Client</h1>
        <p class="text-sm text-gray-500 mt-0.5">Fill in the details below to register a new client</p>
    </div>
   
</div>

@* ── Form ── *@
<form id="addClientForm" asp-action="CreateClientLead" asp-controller="Client" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

        @* ══ LEFT COLUMN ══ *@
        <div class="xl:col-span-2 space-y-6">

            @* Personal Information *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="w-7 h-7 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-blue-600" viewBox="0 0 512 512">
                            <path d="M437.02 74.98C388.668 26.63 324.379 0 256 0S123.332 26.629 74.98 74.98C26.63 123.332 0 187.621 0 256s26.629 132.668 74.98 181.02C123.332 485.37 187.621 512 256 512s132.668-26.629 181.02-74.98C485.37 388.668 512 324.379 512 256s-26.629-132.668-74.98-181.02zM256 269.507c-42.871 0-77.754-34.882-77.754-77.753C178.246 148.879 213.13 114 256 114s77.754 34.879 77.754 77.754c0 42.871-34.883 77.754-77.754 77.754z" />
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-700">Personal Information</h2>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="ClientLead.ClientName" class="block text-xs font-medium text-gray-600 mb-1.5">
                                Name <span class="text-red-500">*</span>
                            </label>
                            <input asp-for="ClientLead.ClientName"
                                   placeholder="e.g. Ahmed Raza"
                                   autocomplete="off"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all placeholder-gray-400" />
                            <span asp-validation-for="ClientLead.ClientName" class="text-xs text-red-500 mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="ClientLead.PhoneNo" class="block text-xs font-medium text-gray-600 mb-1.5">
                                Phone Number
                            </label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-gray-400" viewBox="0 0 473.806 473.806">
                                        <path d="M374.456 293.506c-9.7-10.1-21.4-15.5-33.8-15.5-12.3 0-24.1 5.3-34.2 15.4l-31.6 31.5c-2.6-1.4-5.2-2.7-7.7-4-3.6-1.8-7-3.5-9.9-5.3-29.6-18.8-56.5-43.3-82.3-75-12.5-15.8-20.9-29.1-27-42.6 8.2-7.5 15.8-15.3 23.2-22.8 2.8-2.8 5.6-5.7 8.4-8.5 21-21 21-48.2 0-69.2l-27.3-27.3c-3.1-3.1-6.3-6.3-9.3-9.5-6-6.2-12.3-12.6-18.8-18.6-9.7-9.6-21.3-14.7-33.5-14.7s-24 5.1-34 14.7l-.2.2-34 34.3c-12.8 12.8-20.1 28.4-21.7 46.5-2.4 29.2 6.2 56.4 12.8 74.2 16.2 43.7 40.4 84.2 76.5 127.6 43.8 52.3 96.5 93.6 156.7 122.7 23 10.9 53.7 23.8 87.8 25.6 2.1.1 4.3.2 6.3.2 23.1 0 42.5-8.3 57.7-24.8.1-.2.3-.3.4-.5 5.2-6.3 11.2-12 17.5-18.1 4.3-4.1 8.7-8.4 13-12.9 9.9-10.3 15.1-22.3 15.1-34.6 0-12.4-5.3-24.3-15.4-34.3l-54.9-55.1z" />
                                    </svg>
                                </span>
                                <input asp-for="ClientLead.PhoneNo"
                                       placeholder="+92 300 1234567"
                                       autocomplete="off"
                                       class="w-full text-sm border border-gray-200 rounded-lg pl-9 pr-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all placeholder-gray-400" />
                            </div>
                            <span asp-validation-for="ClientLead.PhoneNo" class="text-xs text-red-500 mt-1 block"></span>
                        </div>
                    </div>
                </div>
            </div>

            @* Company / Business Information *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="w-7 h-7 rounded-lg bg-green-100 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-green-600" viewBox="0 0 512 512">
                            <path d="M480 400H32V112c0-8.8-7.2-16-16-16S0 103.2 0 112v304c0 8.8 7.2 16 16 16h464c8.8 0 16-7.2 16-16s-7.2-16-16-16z" />
                            <path d="M64 368c4.1 0 8.2-1.6 11.3-4.7l99.1-99.1 67.9 67.9c6.2 6.2 16.4 6.2 22.6 0l112-112 41.4 41.4c3.1 3.1 7.2 4.7 11.3 4.7s8.2-1.6 11.3-4.7c6.2-6.2 6.2-16.4 0-22.6l-52.7-52.7c-6.2-6.2-16.4-6.2-22.6 0L253.3 298.4l-67.9-67.9c-6.2-6.2-16.4-6.2-22.6 0l-110.4 110.4c-6.2 6.2-6.2 16.4 0 22.6C55.8 366.4 59.9 368 64 368z" />
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-700">Company / Business Information</h2>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="ClientLead.CompanyName" class="block text-xs font-medium text-gray-600 mb-1.5">Company Name</label>
                            <input asp-for="ClientLead.CompanyName"
                                   placeholder="e.g. Nexova Ltd"
                                   autocomplete="off"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all placeholder-gray-400" />
                            <span asp-validation-for="ClientLead.CompanyName" class="text-xs text-red-500 mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="ClientLead.IndustryId" class="block text-xs font-medium text-gray-600 mb-1.5">Industry</label>
                            <select asp-for="ClientLead.IndustryId"
                                    asp-items="Model.IndustryDropdown"
                                    class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all text-gray-600">
                                <option value="">-- Select Industry --</option>
                            </select>
                            <span asp-validation-for="ClientLead.IndustryId" class="text-xs text-red-500 mt-1 block"></span>
                        </div>
                    </div>
                </div>
            </div>

            @* Address Information *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="w-7 h-7 rounded-lg bg-amber-100 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-amber-600" viewBox="0 0 512 512">
                            <path d="M256 0C166.748 0 94.164 72.584 94.164 161.836c0 87.865 150.051 324.38 154.815 331.93a8.53 8.53 0 0 0 7.021 3.734 8.55 8.55 0 0 0 7.021-3.734c4.764-7.55 154.815-244.065 154.815-331.93C417.836 72.584 345.252 0 256 0zm0 242.371c-44.426 0-80.535-36.109-80.535-80.535S211.574 81.301 256 81.301s80.535 36.109 80.535 80.535S300.426 242.371 256 242.371z" />
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-700">Address Information</h2>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <div>
                        <label asp-for="ClientLead.StreetAddress" class="block text-xs font-medium text-gray-600 mb-1.5">Street Address</label>
                        <input asp-for="ClientLead.StreetAddress"
                               placeholder="e.g. 123 Main Street, Block 5"
                               autocomplete="off"
                               class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all placeholder-gray-400" />
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <div>
                            <label asp-for="ClientLead.City" class="block text-xs font-medium text-gray-600 mb-1.5">City</label>
                            <input asp-for="ClientLead.City"
                                   placeholder="e.g. Karachi"
                                   autocomplete="off"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all placeholder-gray-400" />
                        </div>
                        <div>
                            <label asp-for="ClientLead.Province" class="block text-xs font-medium text-gray-600 mb-1.5">State / Province</label>
                            <input asp-for="ClientLead.Province"
                                   placeholder="e.g. Sindh"
                                   autocomplete="off"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all placeholder-gray-400" />
                        </div>
                        <div>
                            <label asp-for="ClientLead.PostalCode" class="block text-xs font-medium text-gray-600 mb-1.5">Postal Code</label>
                            <input asp-for="ClientLead.PostalCode"
                                   placeholder="e.g. 75500"
                                   autocomplete="off"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all placeholder-gray-400" />
                        </div>
                    </div>
                    <div>
                        <label asp-for="ClientLead.CountryId" class="block text-xs font-medium text-gray-600 mb-1.5">Country</label>
                        <select asp-for="ClientLead.CountryId"
                                asp-items="Model.CountriesDropdown"
                                class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all text-gray-600">
                            <option value="">-- Select Country --</option>
                        </select>
                        <span asp-validation-for="ClientLead.CountryId" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                </div>
            </div>

            @* Notes & Remarks *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="w-7 h-7 rounded-lg bg-purple-100 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-purple-600" viewBox="0 0 512 512">
                            <path d="M467 45.5H45C20.186 45.5 0 65.686 0 90.5v331c0 24.814 20.186 45 45 45h422c24.814 0 45-20.186 45-45v-331c0-24.814-20.186-45-45-45zm15 376c0 8.271-6.729 15-15 15H45c-8.271 0-15-6.729-15-15v-331c0-8.271 6.729-15 15-15h422c8.271 0 15 6.729 15 15v331z" />
                            <path d="M346 166.5H166c-8.284 0-15 6.716-15 15s6.716 15 15 15h180c8.284 0 15-6.716 15-15s-6.716-15-15-15zM286 256.5H166c-8.284 0-15 6.716-15 15s6.716 15 15 15h120c8.284 0 15-6.716 15-15s-6.716-15-15-15z" />
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-700">Notes & Remarks</h2>
                </div>
                <div class="px-6 py-5">
                    <textarea asp-for="ClientLead.Notes"
                              rows="4"
                              placeholder="Any additional notes, special requirements, or background information about this client..."
                              autocomplete="off"
                              class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all resize-none placeholder-gray-400"></textarea>
                </div>
            </div>

        </div>

        @* ══ RIGHT COLUMN ══ *@
        <div class="space-y-6">

            @* Profile Photo *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <h2 class="text-sm font-semibold text-gray-700">Profile Photo</h2>
                </div>
                <div class="px-5 py-5 flex flex-col items-center gap-4">
                    <div id="avatarPreview"
                         class="w-24 h-24 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 text-2xl font-semibold border-4 border-white shadow overflow-hidden">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 fill-blue-400" viewBox="0 0 512 512">
                            <path d="M437.02 74.98C388.668 26.63 324.379 0 256 0S123.332 26.629 74.98 74.98C26.63 123.332 0 187.621 0 256s26.629 132.668 74.98 181.02C123.332 485.37 187.621 512 256 512s132.668-26.629 181.02-74.98C485.37 388.668 512 324.379 512 256s-26.629-132.668-74.98-181.02zM256 482C131.383 482 30 380.617 30 256S131.383 30 256 30s226 101.383 226 226-101.383 226-226 226z" />
                        </svg>
                    </div>
                    <div class="text-center">
                        <label for="photoUpload"
                               class="cursor-pointer text-xs font-medium text-blue-600 border border-blue-200 bg-blue-50 hover:bg-blue-100 px-4 py-2 rounded-lg transition-colors inline-block">
                            Upload Photo
                        </label>
                        <input type="file" id="photoUpload" name="Photo" accept="image/*" class="hidden" onchange="previewPhoto(this)" />
                        <p class="text-xs text-gray-400 mt-2">PNG, JPG up to 2MB</p>
                    </div>
                </div>
            </div>

            @* Lead Details *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <h2 class="text-sm font-semibold text-gray-700">Lead Details</h2>
                </div>
                <div class="px-5 py-5 space-y-4">
                    <div>
                        <label asp-for="ClientLead.LeadSourceID" class="block text-xs font-medium text-gray-600 mb-1.5">Lead Source</label>
                        <select asp-for="ClientLead.LeadSourceID"
                                asp-items="Model.LeadSourceDropdown"
                                class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all text-gray-600">
                            <option value="">-- Select Source --</option>
                        </select>
                        <span asp-validation-for="ClientLead.LeadSourceID" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="ClientLead.LeadStatusID" class="block text-xs font-medium text-gray-600 mb-1.5">Status</label>
                        <select asp-for="ClientLead.LeadStatusID"
                                asp-items="Model.StatusDropdown"
                                class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all text-gray-600">
                            <option value="">-- Select Status --</option>
                        </select>
                        <span asp-validation-for="ClientLead.LeadStatusID" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1.5">Priority</label>

                        <div class="flex gap-2">
                            @foreach (var priority in Model.PriorityDropdown)
                            {
                                var colorClasses = priority.Text switch
                                {
                                    "Low" => "peer-checked:border-green-400 peer-checked:bg-green-50 peer-checked:text-green-700",
                                    "Medium" => "peer-checked:border-amber-400 peer-checked:bg-amber-50 peer-checked:text-amber-700",
                                    "High" => "peer-checked:border-red-400 peer-checked:bg-red-50 peer-checked:text-red-700",
                                    _ => "peer-checked:border-blue-400 peer-checked:bg-blue-50 peer-checked:text-blue-700"
                                };

                                var isChecked =
                                    (Model.ClientLead.PriorityId == null && priority.Value == "1") // default Low
                                    || Model.ClientLead.PriorityId?.ToString() == priority.Value;

                                <label class="flex-1">
                                    <input type="radio"
                                           name="ClientLead.PriorityId"
                                           value="@priority.Value"
                                           class="peer hidden"
                                    @(isChecked ? "checked" : "") />

                                    <span class="block text-center text-xs font-medium border border-gray-200 rounded-lg py-2 cursor-pointer
                                        hover:bg-gray-50 transition-all @colorClasses">
                                        @priority.Text
                                    </span>
                                </label>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* Sidebar Save / Cancel *@
            <div class="bg-white border border-gray-200 rounded-xl px-5 py-4 flex gap-3">
                <a asp-action="ClientLeads" asp-controller="Client"
                       class="flex-1 text-center text-sm text-gray-600 border border-gray-200 rounded-lg px-4 py-2.5 hover:bg-gray-50 transition-colors">
                    Cancel
                </a>
                <button type="submit" form="addClientForm"
                        class="flex-1 flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2.5 rounded-lg transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-white" viewBox="0 0 24 24">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                    </svg>
                    Save Client
                </button>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function previewPhoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const preview = document.getElementById('avatarPreview');
                    preview.innerHTML = '<img src="' + e.target.result + '" class="w-full h-full object-cover" />';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Clear readonly on focus
        document.querySelectorAll('#addClientForm input, #addClientForm textarea').forEach(function(element) {
            element.setAttribute('readonly', 'readonly');
            element.addEventListener('focus', function() {
                this.removeAttribute('readonly');
            });
    
            // For radio buttons
            if (element.type === 'radio') {
                element.removeAttribute('readonly');
            }
        });
    </script>
}
