@section Scripts {
    <script>
        let currentModule = 'products';

        function showModule(moduleName) {
            // Hide all module panels
            document.querySelectorAll('.module-panel').forEach(panel => {
                panel.classList.add('hidden');
            });
        
            // Show selected module panel
            const selectedPanel = document.getElementById(`module-${moduleName}`);
            if (selectedPanel) {
                selectedPanel.classList.remove('hidden');
            }
        
            // Update button active states
            document.querySelectorAll('.module-btn').forEach(btn => {
                btn.classList.remove('bg-blue-50', 'text-blue-700');
                btn.classList.add('text-gray-700');
                const btnModule = btn.getAttribute('data-module');
                if (btnModule === moduleName) {
                    btn.classList.add('bg-blue-50', 'text-blue-700');
                    btn.classList.remove('text-gray-700');
                }
            });
        
            currentModule = moduleName;
        }

        function resetToDefault() {
            if (confirm('Reset all field allowances to default settings?')) {
                // Reset Products
                document.querySelectorAll('input[name="ProductFields"]').forEach(cb => {
                    const value = cb.value;
                    if (value === 'IsProductNameShow' || value === 'HasSKU' || value === 'HasUnit' ||
                        value === 'IsPriceShow' || value === 'IsOpeningBalanceShow' || value === 'HasCategory' ||
                        value === 'HasDescription' || value === 'HasTaxRate') {
                        cb.checked = true;
                    } else if (value === 'IsProductNameRequired') {
                        cb.checked = true;
                    } else {
                        cb.checked = false;
                    }
                });
            
                // Reset Customers
                document.querySelectorAll('input[name="CustomerFields"]').forEach(cb => {
                    const value = cb.value;
                    if (value === 'IsCustomerNameShow' || value === 'IsEmailShow' || value === 'IsPhoneShow' ||
                        value === 'HasBillingAddress' || value === 'HasShippingAddress') {
                        cb.checked = true;
                    } else if (value === 'IsCustomerNameRequired') {
                        cb.checked = true;
                    } else {
                        cb.checked = false;
                    }
                });
            
                // Reset Invoices
                document.querySelectorAll('input[name="InvoiceFields"]').forEach(cb => {
                    const value = cb.value;
                    if (value === 'IsInvoiceNoShow' || value === 'IsDateShow' || value === 'IsDueDateShow' ||
                        value === 'IsSubtotalShow' || value === 'IsTaxShow' || value === 'IsTotalShow') {
                        cb.checked = true;
                    } else if (value === 'IsInvoiceNoRequired' || value === 'IsDateRequired' || value === 'IsTotalRequired') {
                        cb.checked = true;
                    } else {
                        cb.checked = false;
                    }
                });
            
                showToast('Reset to default settings', 'info');
            }
        }

        function saveFieldAllowances() {
            const allowances = {
                products: {},
                customers: {},
                invoices: {}
            };
        
            document.querySelectorAll('input[name="ProductFields"]').forEach(cb => {
                allowances.products[cb.value] = cb.checked;
            });
        
            document.querySelectorAll('input[name="CustomerFields"]').forEach(cb => {
                allowances.customers[cb.value] = cb.checked;
            });
        
            document.querySelectorAll('input[name="InvoiceFields"]').forEach(cb => {
                allowances.invoices[cb.value] = cb.checked;
            });
        
            console.log('Saving allowances:', allowances);
            showToast('Field allowances saved successfully!', 'success');
        
            // Here you would submit via AJAX
            // document.getElementById('fieldAllowanceForm').submit();
        }

        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `fixed bottom-4 right-4 z-50 px-4 py-3 rounded-lg text-white text-sm ${type === 'success' ? 'bg-green-600' : 'bg-blue-600'} shadow-lg transition-all duration-300`;
            toast.innerText = message;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Initialize - show products module by default
        showModule('products');
    </script>
}