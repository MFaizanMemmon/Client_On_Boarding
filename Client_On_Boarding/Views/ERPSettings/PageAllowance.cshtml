@using Client_On_Boarding.DTO
@model PageFieldAllowanceVM
@{
    ViewData["Title"] = "Page Allowances";
}

<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
        <div class="flex items-center gap-2 text-sm text-gray-400 mb-1">
            <a asp-action="Index" asp-controller="Home" class="hover:text-blue-600 transition-colors">Dashboard</a>
            <span>/</span>
            <span class="text-gray-600">Page Allowances</span>
        </div>
        <h1 class="text-2xl font-semibold text-gray-800">Page Allowances</h1>
        <p class="text-sm text-gray-500 mt-0.5">Configure which pages are accessible for each client</p>
    </div>
    <div class="flex items-center gap-3">
        <button type="button" onclick="resetAll()"
                class="text-sm text-gray-600 border border-gray-200 rounded-lg px-4 py-2.5 hover:bg-gray-50 transition-colors">
            Reset
        </button>
        <button type="button" onclick="saveAllowances()"
                class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-white" viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
            </svg>
            Save Allowances
        </button>
    </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    @* LEFT COLUMN *@
    <div class="xl:col-span-1 space-y-6">

        @* Client Selector *@
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <div class="flex items-center gap-3 px-5 py-4 border-b border-gray-100 bg-gray-50">
                <div class="w-7 h-7 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-blue-600" viewBox="0 0 512 512">
                        <path d="M437.02 74.98C388.668 26.63 324.379 0 256 0S123.332 26.629 74.98 74.98C26.63 123.332 0 187.621 0 256s26.629 132.668 74.98 181.02C123.332 485.37 187.621 512 256 512s132.668-26.629 181.02-74.98C485.37 388.668 512 324.379 512 256s-26.629-132.668-74.98-181.02zM111.105 429.297c8.454-72.735 70.989-128.89 144.895-128.89 38.96 0 75.598 15.179 103.156 42.734 23.281 23.285 37.965 53.687 41.742 86.152C361.641 462.172 311.094 482 256 482s-105.637-19.824-144.895-52.703zM256 269.507c-42.871 0-77.754-34.882-77.754-77.753C178.246 148.879 213.13 114 256 114s77.754 34.879 77.754 77.754c0 42.871-34.883 77.754-77.754 77.754z" />
                    </svg>
                </div>
                <h2 class="text-sm font-semibold text-gray-700">Select Client</h2>
            </div>
            <div class="px-5 py-5">
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Client</label>
                <select id="clientSelect"
                        class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all">
                    <option value="">Select a client</option>
                    @foreach (var c in Model.ClientDropdown)
                    {
                        if (c.Value == Model.SelectedClientId?.ToString())
                        {
                            <option value="@c.Value" selected>@c.Text</option>
                        }
                        else
                        {
                            <option value="@c.Value">@c.Text</option>
                        }
                    }
                </select>
            </div>
        </div>

        @* Quick Actions *@
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
                <h2 class="text-sm font-semibold text-gray-700">Quick Actions</h2>
            </div>
            <div class="px-5 py-4 space-y-2">
                <button type="button" onclick="selectAllPages()"
                        class="w-full text-left text-sm text-gray-600 hover:text-blue-600 py-2 px-3 rounded-lg hover:bg-blue-50 transition-colors flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14H7v-2h3v2zm0-4H7v-2h3v2zm0-4H7V7h3v2zm6 8h-3v-2h3v2zm0-4h-3v-2h3v2zm0-4h-3V7h3v2z" />
                    </svg>
                    Select All Pages
                </button>
                <button type="button" onclick="deselectAllPages()"
                        class="w-full text-left text-sm text-gray-600 hover:text-red-600 py-2 px-3 rounded-lg hover:bg-red-50 transition-colors flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14H7v-2h3v2zm0-4H7v-2h3v2zm0-4H7V7h3v2z" />
                    </svg>
                    Deselect All Pages
                </button>
            </div>
        </div>

        @* Summary *@
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
                <h2 class="text-sm font-semibold text-gray-700">Summary</h2>
            </div>
            <div class="px-5 py-4 space-y-3">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-500">Selected Pages</span>
                    <span id="selectedCount" class="font-semibold text-gray-800">0</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-500">Total Pages</span>
                    <span class="font-semibold text-gray-800">@(Model.Pages?.Count ?? 0)</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-2">
                    <div id="progressBar" class="bg-blue-500 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
                </div>
            </div>
        </div>
    </div>

    @* RIGHT COLUMN *@
    <div class="xl:col-span-2 space-y-6">

        @if (!Model.SelectedClientId.HasValue)
        {
            <div class="bg-white border border-gray-200 rounded-xl p-10 text-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 fill-gray-300 mx-auto mb-3" viewBox="0 0 512 512">
                    <path d="M437.02 74.98C388.668 26.63 324.379 0 256 0S123.332 26.629 74.98 74.98C26.63 123.332 0 187.621 0 256s26.629 132.668 74.98 181.02C123.332 485.37 187.621 512 256 512s132.668-26.629 181.02-74.98C485.37 388.668 512 324.379 512 256s-26.629-132.668-74.98-181.02zM111.105 429.297c8.454-72.735 70.989-128.89 144.895-128.89 38.96 0 75.598 15.179 103.156 42.734 23.281 23.285 37.965 53.687 41.742 86.152C361.641 462.172 311.094 482 256 482s-105.637-19.824-144.895-52.703zM256 269.507c-42.871 0-77.754-34.882-77.754-77.753C178.246 148.879 213.13 114 256 114s77.754 34.879 77.754 77.754c0 42.871-34.883 77.754-77.754 77.754z" />
                </svg>
                <p class="text-sm text-gray-400">Select a client on the left to configure their page allowances.</p>
            </div>
        }
        else
        {
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="flex items-center gap-3">
                        <div class="w-7 h-7 rounded-lg bg-red-100 flex items-center justify-center flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-red-600" viewBox="0 0 24 24">
                                <path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z" />
                            </svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-700">All Pages</h2>
                        <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">@(Model.Pages?.Count ?? 0) pages</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-gray-400">Select all</span>
                        <input type="checkbox" id="selectAllPages"
                               onchange="selectAllToggle(this.checked)"
                               class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                    </div>
                </div>
                <div class="px-5 py-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                        @if (Model.Pages != null)
                        {
                            @foreach (var pageItem in Model.Pages)
                            {
                                <label class="flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors border border-transparent hover:border-gray-200">
                                    <input type="checkbox"
                                           name="PageAllowances"
                                           value="@pageItem.Id"
                                           class="page-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                                    <span class="text-sm font-medium text-gray-700">@pageItem.PageName</span>
                                </label>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        const totalPages = @(Model.Pages?.Count ?? 0);

        function updateSummary() {
            const checked = document.querySelectorAll('.page-checkbox:checked').length;
            document.getElementById('selectedCount').innerText = checked;
            const pct = totalPages > 0 ? (checked / totalPages) * 100 : 0;
            document.getElementById('progressBar').style.width = pct + '%';

            const selectAll = document.getElementById('selectAllPages');
            if (selectAll) {
                selectAll.checked = checked === totalPages;
                selectAll.indeterminate = checked > 0 && checked < totalPages;
            }
        }

        function selectAllToggle(isChecked) {
            document.querySelectorAll('.page-checkbox').forEach(cb => cb.checked = isChecked);
            updateSummary();
        }

        function selectAllPages() {
            document.querySelectorAll('.page-checkbox').forEach(cb => cb.checked = true);
            updateSummary();
        }

        function deselectAllPages() {
            document.querySelectorAll('.page-checkbox').forEach(cb => cb.checked = false);
            updateSummary();
        }

        function resetAll() {
            if (confirm('Reset all selections?')) deselectAllPages();
        }

        async function saveAllowances() {
            const clientId = document.getElementById('clientSelect').value;
            if (!clientId) {
                showToast('Please select a client first.', 'error');
                return;
            }

            const pageIds = [...document.querySelectorAll('.page-checkbox:checked')]
                .map(cb => parseInt(cb.value));

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            try {
                const res = await fetch('/ERPSettings/SaveAllowances', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ clientId: parseInt(clientId), pageIds })
                });
                const data = await res.json();
                showToast(data.message, data.success ? 'success' : 'error');
            } catch {
                showToast('Something went wrong.', 'error');
            }
        }

        function showToast(message, type = 'success') {
            const colors = { success: 'bg-green-600', error: 'bg-red-600', info: 'bg-blue-600' };
            const toast = document.createElement('div');
            toast.className = `fixed bottom-4 right-4 z-50 px-4 py-3 rounded-lg text-white text-sm ${colors[type]} shadow-lg transition-opacity duration-300`;
            toast.innerText = message;
            document.body.appendChild(toast);
            setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 3000);
        }

        document.getElementById('clientSelect').addEventListener('change', function () {
            if (this.value) window.location.href = '?clientId=' + this.value;
        });

        document.querySelectorAll('.page-checkbox').forEach(cb => {
            cb.addEventListener('change', updateSummary);
        });

        updateSummary();
    </script>
}