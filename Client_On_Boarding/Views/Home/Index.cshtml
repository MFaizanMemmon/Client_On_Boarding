@{
    ViewData["Title"] = "Dashboard";
}

<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-6">
    <div class="bg-blue-50 rounded-xl p-5">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Client Leads</p>
        <p class="text-3xl font-semibold text-gray-800">156</p>
        <span class="inline-block mt-2 text-xs font-medium bg-green-100 text-green-700 px-2 py-0.5 rounded">+12% this month</span>
    </div>
    <div class="bg-blue-50 rounded-xl p-5">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Active Onboarding</p>
        <p class="text-3xl font-semibold text-gray-800">89</p>
        <span class="inline-block mt-2 text-xs font-medium bg-blue-100 text-blue-700 px-2 py-0.5 rounded">24 in progress</span>
    </div>
    <div class="bg-blue-50 rounded-xl p-5">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Total Receivable</p>
        <p class="text-3xl font-semibold text-gray-800">PKR 2.46M</p>
        <span class="inline-block mt-2 text-xs font-medium bg-red-100 text-red-700 px-2 py-0.5 rounded">PKR 124.5K overdue</span>
    </div>
    <div class="bg-blue-50 rounded-xl p-5">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Business Types</p>
        <p class="text-3xl font-semibold text-gray-800">47</p>
        <span class="inline-block mt-2 text-xs font-medium bg-amber-100 text-amber-700 px-2 py-0.5 rounded">Wheat Industry (28)</span>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div class="bg-white border border-gray-200 rounded-xl p-5">
        <p class="text-sm font-semibold text-gray-700 mb-3">Client Leads Trend — last 6 months</p>
        <div class="flex flex-wrap gap-4 mb-3 text-xs text-gray-500">
            <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm inline-block" style="background:#378add"></span>New Leads</span>
            <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm inline-block" style="background:#1d9e75"></span>Converted</span>
        </div>
        <div class="relative" style="height:200px;"><canvas id="leadsChart"></canvas></div>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl p-5">
        <p class="text-sm font-semibold text-gray-700 mb-3">Onboarding Status</p>
        <div class="flex flex-wrap gap-4 mb-3 text-xs text-gray-500">
            <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm inline-block" style="background:#ef4444"></span>Pending 18</span>
            <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm inline-block" style="background:#378add"></span>In Progress 24</span>
            <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm inline-block" style="background:#1d9e75"></span>Completed 63</span>
            <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm inline-block" style="background:#9ca3af"></span>Rejected 5</span>
        </div>
        <div class="relative" style="height:200px;"><canvas id="onboardingChart"></canvas></div>
    </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-4 mb-6">

    <!-- Recent Client Leads Table -->
    <div class="xl:col-span-2 bg-white border border-gray-200 rounded-xl overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
            <p class="text-sm font-semibold text-gray-700">Recent Client Leads</p>
            <button class="text-xs text-blue-600 hover:underline">View all</button>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full">
                <thead class="bg-gray-800">
                    <tr>
                        <th class="p-4 text-left text-xs font-medium text-white">Client</th>
                        <th class="p-4 text-left text-xs font-medium text-white">Company</th>
                        <th class="p-4 text-left text-xs font-medium text-white">Business Type</th>
                        <th class="p-4 text-left text-xs font-medium text-white">Status</th>
                        <th class="p-4 text-left text-xs font-medium text-white">Date</th>
                        <th class="p-4 text-right text-xs font-medium text-white">Amount</th>
                    </tr>
                </thead>
                <tbody class="whitespace-nowrap divide-y divide-gray-100">
                    <tr class="even:bg-blue-50 hover:bg-blue-50 transition-colors">
                        <td class="p-4 text-sm text-gray-800 font-medium">
                            <div class="flex items-center gap-2">
                                <div class="w-7 h-7 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center text-xs font-bold">AR</div>
                                Ahmed Raza
                            </div>
                        </td>
                        <td class="p-4 text-sm text-gray-600">Nexova Ltd</td>
                        <td class="p-4"><span class="text-xs font-medium bg-amber-100 text-amber-700 px-2.5 py-0.5 rounded-full">Wheat</span></td>
                        <td class="p-4"><span class="text-xs font-medium bg-blue-100 text-blue-700 px-2.5 py-0.5 rounded-full">Contacted</span></td>
                        <td class="p-4 text-sm text-gray-500">2026-03-28</td>
                        <td class="p-4 text-right text-sm font-medium">PKR 50,000</td>
                    </tr>
                    <tr class="even:bg-blue-50 hover:bg-blue-50 transition-colors">
                        <td class="p-4 text-sm text-gray-800 font-medium">
                            <div class="flex items-center gap-2">
                                <div class="w-7 h-7 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center text-xs font-bold">SM</div>
                                Sara Malik
                            </div>
                        </td>
                        <td class="p-4 text-sm text-gray-600">Brightline Co.</td>
                        <td class="p-4"><span class="text-xs font-medium bg-blue-100 text-blue-700 px-2.5 py-0.5 rounded-full">Tech</span></td>
                        <td class="p-4"><span class="text-xs font-medium bg-emerald-100 text-emerald-700 px-2.5 py-0.5 rounded-full">Onboarding</span></td>
                        <td class="p-4 text-sm text-gray-500">2026-04-01</td>
                        <td class="p-4 text-right text-sm font-medium">PKR 75,000</td>
                    </tr>
                    <tr class="even:bg-blue-50 hover:bg-blue-50 transition-colors">
                        <td class="p-4 text-sm text-gray-800 font-medium">
                            <div class="flex items-center gap-2">
                                <div class="w-7 h-7 rounded-full bg-purple-100 text-purple-700 flex items-center justify-center text-xs font-bold">DO</div>
                                David Osei
                            </div>
                        </td>
                        <td class="p-4 text-sm text-gray-600">Apexion Inc.</td>
                        <td class="p-4"><span class="text-xs font-medium bg-purple-100 text-purple-700 px-2.5 py-0.5 rounded-full">Mfg</span></td>
                        <td class="p-4"><span class="text-xs font-medium bg-amber-100 text-amber-700 px-2.5 py-0.5 rounded-full">Follow-up</span></td>
                        <td class="p-4 text-sm text-gray-500">2026-03-15</td>
                        <td class="p-4 text-right text-sm font-medium">PKR 120,000</td>
                    </tr>
                    <tr class="even:bg-blue-50 hover:bg-blue-50 transition-colors">
                        <td class="p-4 text-sm text-gray-800 font-medium">
                            <div class="flex items-center gap-2">
                                <div class="w-7 h-7 rounded-full bg-pink-100 text-pink-700 flex items-center justify-center text-xs font-bold">PN</div>
                                Priya Nair
                            </div>
                        </td>
                        <td class="p-4 text-sm text-gray-600">Cloudform Pvt.</td>
                        <td class="p-4"><span class="text-xs font-medium bg-pink-100 text-pink-700 px-2.5 py-0.5 rounded-full">Health</span></td>
                        <td class="p-4"><span class="text-xs font-medium bg-emerald-100 text-emerald-700 px-2.5 py-0.5 rounded-full">Active</span></td>
                        <td class="p-4 text-sm text-gray-500">2026-02-10</td>
                        <td class="p-4 text-right text-sm font-medium">PKR 95,000</td>
                    </tr>
                    <tr class="even:bg-blue-50 hover:bg-blue-50 transition-colors">
                        <td class="p-4 text-sm text-gray-800 font-medium">
                            <div class="flex items-center gap-2">
                                <div class="w-7 h-7 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center text-xs font-bold">LM</div>
                                Lena Müller
                            </div>
                        </td>
                        <td class="p-4 text-sm text-gray-600">DataSpark GmbH</td>
                        <td class="p-4"><span class="text-xs font-medium bg-blue-100 text-blue-700 px-2.5 py-0.5 rounded-full">Tech</span></td>
                        <td class="p-4"><span class="text-xs font-medium bg-blue-100 text-blue-700 px-2.5 py-0.5 rounded-full">New Lead</span></td>
                        <td class="p-4 text-sm text-gray-500">2026-03-30</td>
                        <td class="p-4 text-right text-sm font-medium">PKR 42,000</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Right Column - Pipeline & Activity -->
    <div class="flex flex-col gap-4">
        <div class="bg-white border border-gray-200 rounded-xl p-5">
            <p class="text-sm font-semibold text-gray-700 mb-4">Onboarding pipeline</p>
            <div class="space-y-3">
                <div>
                    <div class="flex justify-between text-xs text-gray-500 mb-1"><span>Documents submitted</span><span>38 / 89</span></div>
                    <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="h-1.5 rounded-full bg-blue-500" style="width:43%"></div></div>
                </div>
                <div>
                    <div class="flex justify-between text-xs text-gray-500 mb-1"><span>Verification complete</span><span>24 / 89</span></div>
                    <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="h-1.5 rounded-full bg-emerald-500" style="width:27%"></div></div>
                </div>
                <div>
                    <div class="flex justify-between text-xs text-gray-500 mb-1"><span>Contracts signed</span><span>41 / 89</span></div>
                    <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="h-1.5 rounded-full bg-amber-500" style="width:46%"></div></div>
                </div>
                <div>
                    <div class="flex justify-between text-xs text-gray-500 mb-1"><span>Fully onboarded</span><span>18 / 89</span></div>
                    <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="h-1.5 rounded-full bg-pink-500" style="width:20%"></div></div>
                </div>
            </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl p-5">
            <p class="text-sm font-semibold text-gray-700 mb-4">Recent activity</p>
            <div class="space-y-3">
                <div class="flex items-start gap-3">
                    <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center text-xs font-semibold flex-shrink-0">AR</div>
                    <div>
                        <p class="text-sm text-gray-700">Ahmed Raza submitted onboarding docs</p>
                        <p class="text-xs text-gray-400 mt-0.5">2 hours ago</p>
                    </div>
                </div>
                <div class="flex items-start gap-3 pt-3 border-t border-gray-100">
                    <div class="w-8 h-8 rounded-full bg-green-100 text-green-700 flex items-center justify-center text-xs font-semibold flex-shrink-0">PN</div>
                    <div>
                        <p class="text-sm text-gray-700">Priya Nair marked as Active client</p>
                        <p class="text-xs text-gray-400 mt-0.5">5 hours ago</p>
                    </div>
                </div>
                <div class="flex items-start gap-3 pt-3 border-t border-gray-100">
                    <div class="w-8 h-8 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center text-xs font-semibold flex-shrink-0">LM</div>
                    <div>
                        <p class="text-sm text-gray-700">Lena Müller — follow-up scheduled</p>
                        <p class="text-xs text-gray-400 mt-0.5">Yesterday</p>
                    </div>
                </div>
                <div class="flex items-start gap-3 pt-3 border-t border-gray-100">
                    <div class="w-8 h-8 rounded-full bg-purple-100 text-purple-700 flex items-center justify-center text-xs font-semibold flex-shrink-0">DO</div>
                    <div>
                        <p class="text-sm text-gray-700">David Osei payment received PKR 120,000</p>
                        <p class="text-xs text-gray-400 mt-0.5">Yesterday</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <script>
        // Client Leads Trend Chart
        new Chart(document.getElementById('leadsChart'), {
        type: 'bar',
        data: {
        labels: ['Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar'],
        datasets: [
        { label: 'New Leads', data: [12, 19, 15, 25, 22, 30], backgroundColor: '#378add', borderRadius: 4, barPercentage: 0.6 },
        { label: 'Converted', data: [5, 8, 7, 14, 12, 18], backgroundColor: '#1d9e75', borderRadius: 4, barPercentage: 0.6 }
        ]
        },
        options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
        x: { ticks: { color: '#9ca3af', font: { size: 11 } }, grid: { display: false } },
        y: { ticks: { color: '#9ca3af', font: { size: 11 } }, grid: { color: 'rgba(0,0,0,0.05)' }, beginAtZero: true }
        }
        }
        });

        // Onboarding Status Doughnut Chart
        new Chart(document.getElementById('onboardingChart'), {
        type: 'doughnut',
        data: {
        labels: ['Pending', 'In Progress', 'Completed', 'Rejected'],
        datasets: [{ data: [18, 24, 63, 5], backgroundColor: ['#ef4444', '#378add', '#1d9e75', '#9ca3af'], borderWidth: 0, hoverOffset: 4 }]
        },
        options: {
        responsive: true, maintainAspectRatio: false,
        cutout: '68%',
        plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.parsed}` } }
        }
        }
        });
    </script>
}