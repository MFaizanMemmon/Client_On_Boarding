@using Client_On_Boarding.DTO 
@model PageFieldAllowanceVM
@{
    ViewData["Title"] = "Field Allowance";
}

<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100">
    <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        @* ── Page Header ── *@
        <div class="mb-6">
            <div class="flex flex-wrap items-center justify-between gap-4">
                <div>
                    <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
                        <a href="javascript:void(0)" class="hover:text-indigo-600 transition-colors">Dashboard</a>
                        <span>/</span>
                        <span class="text-gray-700 font-medium">Field Allowance</span>
                    </div>
                    <h1 class="text-3xl font-bold text-gray-800">Field Allowance</h1>
                    <p class="text-sm text-gray-500 mt-1">Configure which fields are visible or required per customer and page</p>
                </div>
                <div class="flex items-center gap-3">
                    <button type="button" onclick="resetToDefault()" id="btnReset"
                            class="hidden px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-all duration-200">
                        Reset
                    </button>
                    <button type="button" onclick="saveFieldAllowances()" id="btnSave"
                            class="hidden items-center gap-2 px-6 py-2.5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-all duration-200">
                        Save Settings
                    </button>
                </div>
            </div>
        </div>

        <form id="fieldAllowanceForm" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="selectedCustomerId" name="CustomerId" value="" />
            <input type="hidden" id="selectedPageId" name="PageId" value="" />

            <div class="flex gap-6">
                
                @* LEFT COLUMN - Fixed Width *@
                <div class="w-80 flex-shrink-0 space-y-6">

                    @* Customer Selector Card *@
                    <div class="bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden">
                        <div class="px-5 py-4 border-b border-gray-200 bg-gray-50">
                            <h2 class="text-sm font-bold text-gray-800">Select Customer</h2>
                            <p class="text-xs text-gray-500 mt-1">Choose a customer to configure field access</p>
                        </div>
                        <div class="p-5">
                            <select asp-for="@Model.SelectedClientId"  asp-items=" Model.ClientDropdown" id="customerSelect" onchange="onCustomerChange()"
                                    class="w-full px-3 py-2.5 text-sm border border-gray-300 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 rounded-lg bg-white">
                                <option value="">— Select a customer —</option>
                               
                            </select>

                            <div id="customerPill" class="hidden mt-4 p-3 bg-indigo-50 rounded-lg border border-indigo-200">
                                <div class="flex items-center gap-2">
                                    <div class="w-6 h-6 rounded-full bg-indigo-600 flex items-center justify-center">
                                        <span id="customerInitial" class="text-white text-xs font-bold"></span>
                                    </div>
                                    <p class="text-xs text-gray-700 font-medium">
                                        <span id="customerPillName" class="font-bold text-indigo-600"></span>
                                        <span class="text-green-600 ml-2">✓ Selected</span>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Pages List Card *@
                    <div class="bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden sticky top-6">
                        <div class="px-5 py-4 border-b border-gray-200 bg-gray-50">
                            <div class="flex items-center gap-2">
                                <h2 class="text-sm font-bold text-gray-800">Pages</h2>
                                <span id="pageCount" class="ml-auto text-xs bg-gray-200 text-gray-600 px-2 py-0.5 rounded-full">0</span>
                            </div>
                            <p class="text-xs text-gray-500 mt-1">Select a page to configure its fields</p>
                        </div>
                        
                        <div class="p-3 max-h-[500px] overflow-y-auto">
                            <div id="pagesLoading" class="flex items-center justify-center gap-2 py-8">
                                <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-indigo-600"></div>
                                <span class="text-sm text-gray-500">Loading pages...</span>
                            </div>
                            
                            <div id="pagesList" class="hidden space-y-1">
                            </div>
                            
                            <div id="pagesEmpty" class="hidden text-center py-8">
                                <p class="text-sm text-gray-500">No pages configured for this customer</p>
                            </div>
                        </div>
                    </div>
                </div>

                @* RIGHT COLUMN - Takes all remaining space *@
                <div class="flex-1">
                    
                    <div id="noPageSelected" class="bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden">
                        <div class="text-center py-16">
                            <h3 class="text-lg font-bold text-gray-800 mb-2">No Page Selected</h3>
                            <p class="text-sm text-gray-500">Select a page from the left panel to configure its field settings</p>
                        </div>
                    </div>
                    
                    <div id="fieldConfigArea" class="hidden space-y-6">
                        
                        <div class="bg-white rounded-lg shadow-lg border border-gray-200 px-5 py-4">
                            <div class="flex items-center justify-between flex-wrap gap-3">
                                <div>
                                    <p class="text-xs text-gray-500">Configuring</p>
                                    <h3 id="activePageLabel" class="text-xl font-bold text-gray-800"></h3>
                                </div>
                                <button type="button" onclick="clearPageSelection()"
                                        class="text-sm text-gray-500 hover:text-indigo-600 transition-colors flex items-center gap-2">
                                    ← Change Page
                                </button>
                            </div>
                        </div>
                        
                        @* Products Fields *@
                        <div id="fields-products" class="module-fields-panel hidden bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden">
                            <div class="px-5 py-4 border-b border-gray-200 bg-blue-50">
                                <h3 class="font-bold text-gray-800">Products Field Settings</h3>
                                <p class="text-xs text-gray-500 mt-1">Toggle which fields this customer can see or must fill</p>
                            </div>
                            <div class="p-5">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Product Name</label>
                                            <p class="text-xs text-gray-400">Main product identifier</p>
                                        </div>
                                        <div class="flex gap-4">
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="ProductFields" value="IsProductNameShow" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                                <span class="text-xs text-gray-600">Show</span>
                                            </label>
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="ProductFields" value="IsProductNameRequired" class="rounded border-gray-300 text-red-500 focus:ring-red-500" checked />
                                                <span class="text-xs text-gray-600">Req</span>
                                            </label>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">SKU / Barcode</label>
                                            <p class="text-xs text-gray-400">Stock Keeping Unit</p>
                                        </div>
                                        <div class="flex gap-4">
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="ProductFields" value="HasSKU" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                                <span class="text-xs text-gray-600">Show</span>
                                            </label>
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="ProductFields" value="HasSKURequired" class="rounded border-gray-300 text-red-500 focus:ring-red-500" />
                                                <span class="text-xs text-gray-600">Req</span>
                                            </label>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Unit</label>
                                            <p class="text-xs text-gray-400">Unit of measurement</p>
                                        </div>
                                        <div class="flex gap-4">
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="ProductFields" value="HasUnit" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                                <span class="text-xs text-gray-600">Show</span>
                                            </label>
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="ProductFields" value="HasUnitRequired" class="rounded border-gray-300 text-red-500 focus:ring-red-500" />
                                                <span class="text-xs text-gray-600">Req</span>
                                            </label>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Price</label>
                                            <p class="text-xs text-gray-400">Selling price</p>
                                        </div>
                                        <div class="flex gap-4">
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="ProductFields" value="IsPriceShow" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                                <span class="text-xs text-gray-600">Show</span>
                                            </label>
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="ProductFields" value="IsPriceRequired" class="rounded border-gray-300 text-red-500 focus:ring-red-500" />
                                                <span class="text-xs text-gray-600">Req</span>
                                            </label>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Cost Price</label>
                                            <p class="text-xs text-gray-400">Purchase cost</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="ProductFields" value="HasCostPrice" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Opening Balance</label>
                                            <p class="text-xs text-gray-400">Initial stock quantity</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="ProductFields" value="IsOpeningBalanceShow" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Min. Stock Alert</label>
                                            <p class="text-xs text-gray-400">Reorder threshold</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="ProductFields" value="HasMinStock" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Category</label>
                                            <p class="text-xs text-gray-400">Product category/group</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="ProductFields" value="HasCategory" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Description</label>
                                            <p class="text-xs text-gray-400">Detailed description</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="ProductFields" value="HasDescription" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Tax Rate</label>
                                            <p class="text-xs text-gray-400">GST / VAT / Sales tax</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="ProductFields" value="HasTaxRate" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        @* Customers Fields *@
                        <div id="fields-customers" class="module-fields-panel hidden bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden">
                            <div class="px-5 py-4 border-b border-gray-200 bg-green-50">
                                <h3 class="font-bold text-gray-800">Customers Field Settings</h3>
                                <p class="text-xs text-gray-500 mt-1">Toggle which customer fields are visible or required</p>
                            </div>
                            <div class="p-5">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Customer Name</label>
                                            <p class="text-xs text-gray-400">Full name or company name</p>
                                        </div>
                                        <div class="flex gap-4">
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="CustomerFields" value="IsCustomerNameShow" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                                <span class="text-xs text-gray-600">Show</span>
                                            </label>
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="CustomerFields" value="IsCustomerNameRequired" class="rounded border-gray-300 text-red-500 focus:ring-red-500" checked />
                                                <span class="text-xs text-gray-600">Req</span>
                                            </label>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Email Address</label>
                                            <p class="text-xs text-gray-400">Primary email address</p>
                                        </div>
                                        <div class="flex gap-4">
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="CustomerFields" value="IsEmailShow" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                                <span class="text-xs text-gray-600">Show</span>
                                            </label>
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="CustomerFields" value="IsEmailRequired" class="rounded border-gray-300 text-red-500 focus:ring-red-500" />
                                                <span class="text-xs text-gray-600">Req</span>
                                            </label>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Phone Number</label>
                                            <p class="text-xs text-gray-400">Contact phone number</p>
                                        </div>
                                        <div class="flex gap-4">
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="CustomerFields" value="IsPhoneShow" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                                <span class="text-xs text-gray-600">Show</span>
                                            </label>
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="CustomerFields" value="IsPhoneRequired" class="rounded border-gray-300 text-red-500 focus:ring-red-500" />
                                                <span class="text-xs text-gray-600">Req</span>
                                            </label>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Billing Address</label>
                                            <p class="text-xs text-gray-400">Street, city, state, zip</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="CustomerFields" value="HasBillingAddress" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Shipping Address</label>
                                            <p class="text-xs text-gray-400">Delivery address</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="CustomerFields" value="HasShippingAddress" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Tax Number / GSTIN</label>
                                            <p class="text-xs text-gray-400">For tax invoice purposes</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="CustomerFields" value="HasTaxNumber" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Credit Limit</label>
                                            <p class="text-xs text-gray-400">Maximum allowed credit</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="CustomerFields" value="HasCreditLimit" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Opening Balance</label>
                                            <p class="text-xs text-gray-400">Previous outstanding balance</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="CustomerFields" value="IsOpeningBalanceShow" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        @* Invoices Fields *@
                        <div id="fields-invoices" class="module-fields-panel hidden bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden">
                            <div class="px-5 py-4 border-b border-gray-200 bg-purple-50">
                                <h3 class="font-bold text-gray-800">Invoices Field Settings</h3>
                                <p class="text-xs text-gray-500 mt-1">Toggle which invoice fields are visible or required</p>
                            </div>
                            <div class="p-5">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Invoice Number</label>
                                            <p class="text-xs text-gray-400">Unique invoice identifier</p>
                                        </div>
                                        <div class="flex gap-4">
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="InvoiceFields" value="IsInvoiceNoShow" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                                <span class="text-xs text-gray-600">Show</span>
                                            </label>
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="InvoiceFields" value="IsInvoiceNoRequired" class="rounded border-gray-300 text-red-500 focus:ring-red-500" checked />
                                                <span class="text-xs text-gray-600">Req</span>
                                            </label>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Invoice Date</label>
                                            <p class="text-xs text-gray-400">Date of issue</p>
                                        </div>
                                        <div class="flex gap-4">
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="InvoiceFields" value="IsDateShow" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                                <span class="text-xs text-gray-600">Show</span>
                                            </label>
                                            <label class="inline-flex items-center gap-1 cursor-pointer">
                                                <input type="checkbox" name="InvoiceFields" value="IsDateRequired" class="rounded border-gray-300 text-red-500 focus:ring-red-500" checked />
                                                <span class="text-xs text-gray-600">Req</span>
                                            </label>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Due Date</label>
                                            <p class="text-xs text-gray-400">Payment deadline</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="InvoiceFields" value="IsDueDateShow" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Subtotal</label>
                                            <p class="text-xs text-gray-400">Amount before tax</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1 cursor-pointer">
                                            <input type="checkbox" name="InvoiceFields" value="IsSubtotalShow" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked />
                                            <span class="text-xs text-gray-600">Show</span>
                                        </label>
                                    </div>
                                    
                                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div>
                                            <label class="text-sm font-semibold text-gray-700">Tax Amount</label>
                                            <p class="text-xs text-gray-400">Total tax charged</p>
                                        </div>
