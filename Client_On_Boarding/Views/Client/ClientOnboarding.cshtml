@{
    ViewData["Title"] = "Client Onboarding";
}

@* ── Page Header ── *@
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-semibold text-gray-800">Client Onboarding</h1>
        <p class="text-sm text-gray-500 mt-0.5">Review and complete client onboarding applications</p>
    </div>
    <a asp-action="CreateOnboarding" asp-controller="Client"
           class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2.5 rounded-lg transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-white" viewBox="0 0 24 24">
            <path d="M18 2c2.206 0 4 1.794 4 4v12c0 2.206-1.794 4-4 4H6c-2.206 0-4-1.794-4-4V6c0-2.206 1.794-4 4-4zm0-2H6a6 6 0 0 0-6 6v12a6 6 0 0 0 6 6h12a6 6 0 0 0 6-6V6a6 6 0 0 0-6-6z" />
            <path d="M12 18a1 1 0 0 1-1-1V7a1 1 0 0 1 2 0v10a1 1 0 0 1-1 1z" />
            <path d="M6 12a1 1 0 0 1 1-1h10a1 1 0 0 1 0 2H7a1 1 0 0 1-1-1z" />
        </svg>
        New Onboarding
    </a>
</div>

@* ── Summary Cards (Onboarding specific) ── *@
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
    <div class="bg-blue-50 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Pending Review</p>
        <p class="text-2xl font-semibold text-gray-800">18</p>
        <span class="inline-block mt-1.5 text-xs font-medium bg-amber-100 text-amber-700 px-2 py-0.5 rounded">Awaiting docs</span>
    </div>
    <div class="bg-blue-50 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">In Progress</p>
        <p class="text-2xl font-semibold text-gray-800">24</p>
        <span class="inline-block mt-1.5 text-xs font-medium bg-blue-100 text-blue-700 px-2 py-0.5 rounded">Verification</span>
    </div>
    <div class="bg-blue-50 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Completed</p>
        <p class="text-2xl font-semibold text-gray-800">63</p>
        <span class="inline-block mt-1.5 text-xs font-medium bg-green-100 text-green-700 px-2 py-0.5 rounded">This quarter</span>
    </div>
    <div class="bg-blue-50 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Avg. Time</p>
        <p class="text-2xl font-semibold text-gray-800">4.2d</p>
        <span class="inline-block mt-1.5 text-xs font-medium bg-purple-100 text-purple-700 px-2 py-0.5 rounded">-1.5d vs last</span>
    </div>
</div>

@* ── Filters & Search ── *@
