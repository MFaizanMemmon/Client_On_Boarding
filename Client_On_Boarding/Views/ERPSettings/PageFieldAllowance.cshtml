</div>

@section Scripts {
    <script>
        const PAGE_META = {
            products: { label: 'Products' },
            customers: { label: 'Customers' },
            invoices: { label: 'Invoices' },
            sales_orders: { label: 'Sales Orders' },
            purchase_orders: { label: 'Purchase Orders' },
            employees: { label: 'Employees' }
        };

        let currentSelectedPage = null;

        function onCustomerChange() {
            const select = document.getElementById('customerSelect');
            const val = select.value;

            document.getElementById('pagesList').classList.add('hidden');
            document.getElementById('fieldConfigArea').classList.add('hidden');
            document.getElementById('noPageSelected').classList.remove('hidden');
            document.getElementById('btnReset').classList.add('hidden');
            document.getElementById('btnSave').classList.add('hidden');
            
            if (!val) {
                document.getElementById('customerPill').classList.add('hidden');
                document.getElementById('selectedCustomerId').value = '';
                document.getElementById('pagesLoading').classList.remove('hidden');
                document.getElementById('pagesEmpty').classList.add('hidden');
                return;
            }

            const name = select.options[select.selectedIndex].text;
            document.getElementById('customerPillName').textContent = name;
            document.getElementById('customerInitial').textContent = name.charAt(0).toUpperCase();
            document.getElementById('customerPill').classList.remove('hidden');
            document.getElementById('selectedCustomerId').value = val;

            document.getElementById('pagesLoading').classList.remove('hidden');
            document.getElementById('pagesList').classList.add('hidden');
            document.getElementById('pagesEmpty').classList.add('hidden');

            setTimeout(() => {
                const demoPages = ['products', 'customers', 'invoices', 'sales_orders', 'purchase_orders', 'employees'];
                renderPagesList(demoPages);
            }, 500);
        }

        function renderPagesList(pageIds) {
            const pagesList = document.getElementById('pagesList');
            pagesList.innerHTML = '';
            
            document.getElementById('pagesLoading').classList.add('hidden');

            if (!pageIds || pageIds.length === 0) {
                document.getElementById('pagesEmpty').classList.remove('hidden');
                return;
            }

            document.getElementById('pageCount').textContent = pageIds.length;

            pageIds.forEach(id => {
                const meta = PAGE_META[id];
                if (!meta) return;

                const pageItem = document.createElement('div');
                pageItem.className = `page-item flex items-center justify-between p-3 rounded-lg cursor-pointer transition-all duration-200 hover:bg-indigo-50 border border-transparent hover:border-indigo-200`;
                pageItem.setAttribute('data-page', id);
                pageItem.onclick = () => selectPage(id);
                pageItem.innerHTML = `
                    <div>
                        <p class="text-sm font-semibold text-gray-700">${meta.label}</p>
                        <p class="text-xs text-gray-400">Configure field settings</p>
                    </div>
                    <span class="text-gray-300">→</span>
                `;
                pagesList.appendChild(pageItem);
            });

            pagesList.classList.remove('hidden');
        }

        function selectPage(pageId) {
            const meta = PAGE_META[pageId];
            if (!meta) return;

            document.querySelectorAll('.page-item').forEach(item => {
                const id = item.getAttribute('data-page');
                if (id === pageId) {
                    item.classList.add('bg-indigo-50', 'border-indigo-300');
                    item.classList.remove('border-transparent');
                } else {
                    item.classList.remove('bg-indigo-50', 'border-indigo-300');
                    item.classList.add('border-transparent');
                }
            });

            currentSelectedPage = pageId;
            document.getElementById('selectedPageId').value = pageId;
            document.getElementById('activePageLabel').textContent = meta.label;
            
            document.getElementById('fieldConfigArea').classList.remove('hidden');
            document.getElementById('noPageSelected').classList.add('hidden');
            
            document.getElementById('btnReset').classList.remove('hidden');
            document.getElementById('btnSave').classList.remove('hidden');

            document.querySelectorAll('.module-fields-panel').forEach(p => p.classList.add('hidden'));
            const panel = document.getElementById(`fields-${pageId}`);
            if (panel) panel.classList.remove('hidden');
        }

        function clearPageSelection() {
            currentSelectedPage = null;
            document.getElementById('selectedPageId').value = '';
            document.getElementById('fieldConfigArea').classList.add('hidden');
            document.getElementById('noPageSelected').classList.remove('hidden');
            document.getElementById('btnReset').classList.add('hidden');
            document.getElementById('btnSave').classList.add('hidden');
            
            document.querySelectorAll('.page-item').forEach(item => {
                item.classList.remove('bg-indigo-50', 'border-indigo-300');
                item.classList.add('border-transparent');
            });
        }

        function resetToDefault() {
            if (!currentSelectedPage) return;
            if (!confirm('Reset all field settings for this page to default?')) return;

            const defaults = {
                products: ['IsProductNameShow', 'IsProductNameRequired', 'HasSKU', 'HasUnit', 'IsPriceShow', 'IsOpeningBalanceShow', 'HasCategory', 'HasDescription', 'HasTaxRate'],
                customers: ['IsCustomerNameShow', 'IsCustomerNameRequired', 'IsEmailShow', 'IsPhoneShow', 'HasBillingAddress', 'HasShippingAddress'],
                invoices: ['IsInvoiceNoShow', 'IsInvoiceNoRequired', 'IsDateShow', 'IsDateRequired', 'IsDueDateShow', 'IsSubtotalShow', 'IsTaxShow', 'IsTotalShow', 'IsTotalRequired']
            };

            const panel = document.getElementById(`fields-${currentSelectedPage}`);
            if (!panel) return;
            panel.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                cb.checked = (defaults[currentSelectedPage] || []).includes(cb.value);
            });
            alert('Reset to default settings');
        }

        function saveFieldAllowances() {
            const customerId = document.getElementById('selectedCustomerId').value;
            if (!customerId || !currentSelectedPage) {
                alert('Please select a customer and page.');
                return;
            }

            const fields = {};
            const panel = document.getElementById(`fields-${currentSelectedPage}`);
            if (panel) {
                panel.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                    fields[cb.value] = cb.checked;
                });
            }

            console.log('Saving:', { customerId, pageId: currentSelectedPage, fields });
            alert('Field allowances saved successfully!');
        }
    </script>
}