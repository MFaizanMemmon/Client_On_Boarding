@using Client_On_Boarding.DTO
@model ClientLeadVM
@{
    ViewData["Title"] = "Create Onboarding";
}

@* ── Page Header ── *@
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
        <div class="flex items-center gap-2 text-sm text-gray-400 mb-1">
            <a asp-controller="Home" asp-action="Index" class="hover:text-blue-600 transition-colors">Dashboard</a>
            <span>/</span>
            <a asp-controller="Client" asp-action="ClientOnboarding" class="hover:text-blue-600 transition-colors">Client Onboarding</a>
            <span>/</span>
            <span class="text-gray-600">Create Onboarding</span>
        </div>
        <h1 class="text-2xl font-semibold text-gray-800">Create Onboarding</h1>
        <p class="text-sm text-gray-500 mt-0.5">Set up a new ERP subscription for a client lead</p>
    </div>
</div>

<form id="onboardingForm" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

        @* ── LEFT COLUMN ── *@
        <div class="xl:col-span-2 space-y-6">

            @* Client Selection *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="w-7 h-7 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-blue-600" viewBox="0 0 512 512">
                            <path d="M437.02 74.98C388.668 26.63 324.379 0 256 0S123.332 26.629 74.98 74.98C26.63 123.332 0 187.621 0 256s26.629 132.668 74.98 181.02C123.332 485.37 187.621 512 256 512s132.668-26.629 181.02-74.98C485.37 388.668 512 324.379 512 256s-26.629-132.668-74.98-181.02zM111.105 429.297c8.454-72.735 70.989-128.89 144.895-128.89 38.96 0 75.598 15.179 103.156 42.734 23.281 23.285 37.965 53.687 41.742 86.152C361.641 462.172 311.094 482 256 482s-105.637-19.824-144.895-52.703zM256 269.507c-42.871 0-77.754-34.882-77.754-77.753C178.246 148.879 213.13 114 256 114s77.754 34.879 77.754 77.754c0 42.871-34.883 77.754-77.754 77.754z"/>
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-700">Client Information</h2>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Select Lead <span class="text-red-500">*</span></label>
                            <select asp-for="@Model.ClientLead.Id" asp-items="Model.ClientDropdown" name="LeadId" id="leadSelect" onchange="populateLead(this)"
                                    class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all text-gray-600">
                            
                                    <option value="0">Select Lead</option>
                                </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Client Name <span class="text-red-500">*</span></label>
                            <input type="text" name="ClientName" id="clientName" placeholder="Auto-filled from lead"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all placeholder-gray-400 bg-gray-50" readonly />
                        </div>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Company Name</label>
                            <input type="text" name="CompanyName" id="clientCompany" placeholder="Auto-filled from lead"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all placeholder-gray-400 bg-gray-50" readonly />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Phone</label>
                            <input type="tel" name="ClientPhone" id="clientPhone" placeholder="Auto-filled from lead"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all placeholder-gray-400 bg-gray-50" readonly />
                        </div>
                    </div>
                </div>
            </div>

            @* ERP Subscription Plan *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="w-7 h-7 rounded-lg bg-green-100 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-green-600" viewBox="0 0 64 64">
                            <path d="M32.667 5.11A25.116 25.116 0 0 0 32 5.045V2.88a2.08 2.08 0 1 0-4.16 0v2.165C15.027 6.102 4.96 16.837 4.96 29.92v18.5L3.47 52.8h-.59a2.08 2.08 0 1 0 0 4.16h54.08a2.08 2.08 0 1 0 0-4.16h-.59l-1.49-4.38v-9.568a18.585 18.585 0 0 1-4.16 1.209v8.703a2.08 2.08 0 0 0 .11.67l1.145 3.366H7.865l1.144-3.366a2.08 2.08 0 0 0 .111-.67V29.92c0-11.488 9.312-20.8 20.8-20.8.142 0 .285.001.426.004a18.7 18.7 0 0 1 2.32-4.014zM23.68 61.12a2.08 2.08 0 0 1 2.08-2.08h8.32a2.08 2.08 0 1 1 0 4.16h-8.32a2.08 2.08 0 0 1-2.08-2.08z"/>
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-700">ERP Subscription Plan</h2>
                </div>
                <div class="px-6 py-5 space-y-5">

                    @* ── Plan Cards – JS-driven, no broken peer: hacks ── *@
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-3">Select Plan <span class="text-red-500">*</span></label>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3" id="planCards">

                            @* Starter - Default Selected *@
                            <div class="plan-card plan-card--active cursor-pointer border-2 border-blue-500 bg-blue-50 rounded-xl p-4 hover:border-blue-600 transition-all h-full"
                                 data-plan="starter" data-price="1500" onclick="selectPlan(this)">
                                <input type="radio" name="Plan" value="starter" class="hidden" checked />

                                <div class="flex items-center justify-between mb-3">
                                    <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide plan-label">Starter</span>
                                    <div class="plan-dot w-4 h-4 rounded-full border-2 border-blue-500 bg-blue-500 flex items-center justify-center transition-all">
                                        <div class="plan-dot-inner w-1.5 h-1.5 rounded-full bg-white scale-100 transition-transform"></div>
                                    </div>
                                </div>

                                <p class="text-2xl font-bold text-gray-800">Rs 1,500<span class="text-sm font-normal text-gray-500">/mo</span></p>

                                <ul class="mt-3 space-y-1.5 text-xs text-gray-500">
                                    <li class="flex items-center gap-1.5">
                                        <svg class="w-3.5 h-3.5 fill-green-500 flex-shrink-0" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" /></svg>
                                        1 user only
                                    </li>
                                    <li class="flex items-center gap-1.5">
                                        <svg class="w-3.5 h-3.5 fill-green-500 flex-shrink-0" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" /></svg>
                                        Inventory module
                                    </li>
                                    <li class="flex items-center gap-1.5">
                                        <svg class="w-3.5 h-3.5 fill-green-500 flex-shrink-0" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" /></svg>
                                        Basic reports
                                    </li>
                                    <li class="flex items-center gap-1.5">
                                        <svg class="w-3.5 h-3.5 fill-gray-300 flex-shrink-0" viewBox="0 0 24 24"><path d="M18.3 5.71L12 12.01 5.7 5.71 4.29 7.12 10.59 13.42 4.29 19.72 5.7 21.13 12 14.83 18.3 21.13 19.71 19.72 13.41 13.42 19.71 7.12z" /></svg>
                                        <span class="text-gray-400">Multi-branch</span>
                                    </li>
                                </ul>
                            </div>

                            @* Professional - Disabled *@
                            <div class="plan-card cursor-not-allowed border-2 border-gray-200 bg-gray-100 opacity-60 rounded-xl p-4 transition-all h-full relative"
                                 data-plan="professional" data-price="3000">

                                <input type="radio" name="Plan" value="professional" class="hidden" disabled />

                                <div class="flex items-center justify-between mb-3">
                                    <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide plan-label">Professional</span>
                                    <div class="plan-dot w-4 h-4 rounded-full border-2 border-gray-300 flex items-center justify-center transition-all">
                                        <div class="plan-dot-inner w-1.5 h-1.5 rounded-full bg-white scale-0 transition-transform"></div>
                                    </div>
                                </div>

                                <p class="text-2xl font-bold text-gray-500">Rs 3,000<span class="text-sm font-normal text-gray-400">/mo</span></p>

                                <ul class="mt-3 space-y-1.5 text-xs text-gray-400">
                                    <li class="flex items-center gap-1.5">Up to 10 users</li>
                                    <li class="flex items-center gap-1.5">All modules</li>
                                    <li class="flex items-center gap-1.5">Advanced reports</li>
                                    <li class="flex items-center gap-1.5">Multi-branch</li>
                                </ul>
                            </div>

                            @* Enterprise - Disabled *@
                            <div class="plan-card cursor-not-allowed border-2 border-gray-200 bg-gray-100 opacity-60 rounded-xl p-4 transition-all h-full"
                                 data-plan="enterprise" data-price="5000">

                                <input type="radio" name="Plan" value="enterprise" class="hidden" disabled />

                                <div class="flex items-center justify-between mb-3">
                                    <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide plan-label">Enterprise</span>
                                    <div class="plan-dot w-4 h-4 rounded-full border-2 border-gray-300 flex items-center justify-center transition-all">
                                        <div class="plan-dot-inner w-1.5 h-1.5 rounded-full bg-white scale-0 transition-transform"></div>
                                    </div>
                                </div>

                                <p class="text-2xl font-bold text-gray-500">Rs 5,000<span class="text-sm font-normal text-gray-400">/mo</span></p>

                                <ul class="mt-3 space-y-1.5 text-xs text-gray-400">
                                    <li class="flex items-center gap-1.5">Unlimited users</li>
                                    <li class="flex items-center gap-1.5">Custom modules</li>
                                    <li class="flex items-center gap-1.5">Dedicated support</li>
                                    <li class="flex items-center gap-1.5">On-site training</li>
                                </ul>
                            </div>

                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Billing Cycle <span class="text-red-500">*</span></label>
                            <select name="BillingCycle" id="billingCycle"
                                    class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all text-gray-600">
                                <option value="monthly">Monthly</option>
                                <option value="quarterly">Quarterly (5% off)</option>
                                <option value="annually">Annually (15% off)</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Subscription Start Date <span class="text-red-500">*</span></label>
                            <input type="date" name="StartDate"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all text-gray-600" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-2">ERP Modules Required</label>

                        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                            @{
                                var modules = new[] {
                                    "Admin", "Accounting", "Warehouse",
                                    "Order Booking", "HR & Payroll",
                                    "Manufacturing"
                                };
                            }

                            @foreach (var mod in modules)
                            {
                                var isAccounting = mod == "Accounting";

                                <label class="flex items-center gap-2 border border-gray-200 rounded-lg px-3 py-2 transition-colors
                                    @(isAccounting ? "cursor-pointer hover:bg-gray-50" : "cursor-not-allowed bg-gray-100 opacity-60")">
                                    <input type="checkbox"
                                           name="Modules"
                                           value="@mod"
                                    @(isAccounting ? "" : "disabled")
                                           class="rounded border-gray-300 text-blue-600 focus:ring-blue-400 w-3.5 h-3.5" />

                                    <span class="text-xs text-gray-700">@mod</span>
                                </label>
                            }
                        </div>
                    </div>

                </div>
            </div>

            @* ERP Access Setup *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100 bg-gray-50">
                    <div class="w-7 h-7 rounded-lg bg-purple-100 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-purple-600" viewBox="0 0 24 24">
                            <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-700">ERP Access Credentials</h2>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <div class="bg-amber-50 border border-amber-100 rounded-lg px-4 py-3 flex items-start gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-amber-500 flex-shrink-0 mt-0.5" viewBox="0 0 24 24">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                        </svg>
                        <p class="text-xs text-amber-700">These credentials will be emailed to the client upon activation. They can be changed after first login.</p>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">ERP Username <span class="text-red-500">*</span></label>
                            <input type="text" name="ErpUsername" placeholder="e.g. ahmed.nexova"
                                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all placeholder-gray-400" />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1.5">Temporary Password <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <input type="text" name="TempPassword" id="tempPassword" placeholder="Auto-generate or enter"
                                       class="w-full text-sm border border-gray-200 rounded-lg px-3 pr-24 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all placeholder-gray-400" />
                                <button type="button" onclick="generatePassword()"
                                        class="absolute inset-y-0 right-0 px-3 text-xs font-medium text-blue-600 hover:text-blue-700 border-l border-gray-200 transition-colors">
                                    Generate
                                </button>
                            </div>
                        </div>
                    </div>
                 
                </div>
            </div>

        </div>

        @* ── RIGHT COLUMN ── *@
        <div class="space-y-6">

            @* Pricing Summary *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <h2 class="text-sm font-semibold text-gray-700">Pricing Summary</h2>
                </div>
                <div class="px-5 py-5 space-y-3">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-500">Plan</span>
                        <span class="font-medium text-gray-800" id="summaryPlan">Professional</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-500">Base Price</span>
                        <span class="font-medium text-gray-800" id="summaryPrice">$99.00</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-500">Billing Cycle</span>
                        <span class="font-medium text-gray-800" id="summaryCycle">Monthly</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-500">Discount</span>
                        <span class="font-medium text-green-600" id="summaryDiscount">–</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-500">Setup Fee</span>
                        <span class="font-medium text-gray-800">Rs 0.00</span>
                    </div>
                    <hr class="border-gray-100" />
                    <div class="flex justify-between">
                        <span class="text-sm font-semibold text-gray-700">Total / Month</span>
                        <span class="text-base font-bold text-blue-600" id="summaryTotal">$99.00</span>
                    </div>
                </div>
            </div>
            @* Status *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <h2 class="text-sm font-semibold text-gray-700">Status</h2>
                </div>

                <div class="px-5 py-5">
                    <label class="block text-xs font-medium text-gray-600 mb-1.5">
                        Onboarding Status <span class="text-red-500">*</span>
                    </label>

                    <select name="Status" id="status"
                            class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100 transition-all text-gray-600">
                        <option value="Pending" selected>Pending</option>
                        <option value="InProgress">In Progress</option>
                        <option value="Active">Active</option>
                        <option value="OnHold">On Hold</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
            </div>
            @* Internal Notes *@
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
                    <h2 class="text-sm font-semibold text-gray-700">Internal Notes</h2>
                </div>
                <div class="px-5 py-5">
                    <textarea name="Notes" rows="3" placeholder="Any notes for the onboarding team..."
                              class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-400 transition-all resize-none placeholder-gray-400"></textarea>
                </div>
            </div>

            @* Action Buttons *@
            <div class="bg-white border border-gray-200 rounded-xl px-5 py-4 flex gap-3">
                <a href="javascript:void(0)"
                   class="flex-1 text-center text-sm text-gray-600 border border-gray-200 rounded-lg px-4 py-2.5 hover:bg-gray-50 transition-colors">
                    Cancel
                </a>
                <button type="submit" form="onboardingForm"
                        class="flex-1 flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2.5 rounded-lg transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-white" viewBox="0 0 24 24">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                    </svg>
                    Submit
                </button>
            </div>

        </div>
    </div>
</form>

@section Scripts {
<script>
(function () {

    /* ── Plan data ── */
    const PLANS = {
        starter:      { label: 'Starter',      price: 1500  },
        professional: { label: 'Professional', price: 3000  },
        enterprise:   { label: 'Enterprise',   price: 5000 }
    };

    /* ── Discount map ── */
    const DISCOUNTS = {
        monthly:   { label: 'None',  pct: 0    },
        quarterly: { label: '5%',    pct: 0.05 },
        annually:  { label: '15%',   pct: 0.15 }
    };

    let activePlan  = 'professional';
    let activeCycle = 'monthly';

    /* ── selectPlan: called from onclick on each card div ── */
    window.selectPlan = function (card) {
        const plan = card.dataset.plan;
        if (plan === activePlan) return;
        activePlan = plan;

        /* Update all cards */
        document.querySelectorAll('.plan-card').forEach(c => {
            const isActive = c.dataset.plan === plan;

            /* Border / background */
            c.classList.toggle('border-blue-500', isActive);
            c.classList.toggle('bg-blue-50',      isActive);
            c.classList.toggle('border-gray-200', !isActive);
            c.classList.remove('hover:border-gray-300', 'hover:border-blue-600');
            c.classList.add(isActive ? 'hover:border-blue-600' : 'hover:border-gray-300');

            /* Label colour */
            const lbl = c.querySelector('.plan-label');
            lbl.classList.toggle('text-blue-600', isActive);
            lbl.classList.toggle('text-gray-500',  !isActive);

            /* Radio dot */
            const dot      = c.querySelector('.plan-dot');
            const dotInner = c.querySelector('.plan-dot-inner');
            dot.classList.toggle('border-blue-500', isActive);
            dot.classList.toggle('bg-blue-500',     isActive);
            dot.classList.toggle('border-gray-300', !isActive);
            dot.classList.toggle('bg-transparent',  !isActive);
            dotInner.style.transform = isActive ? 'scale(1)' : 'scale(0)';

            /* Hidden radio input */
            c.querySelector('input[type="radio"]').checked = isActive;
        });

        updateSummary();
    };

    /* ── Billing cycle change ── */
    document.getElementById('billingCycle').addEventListener('change', function () {
        activeCycle = this.value;
        updateSummary();
    });

    /* ── Update pricing summary ── */
    function updateSummary() {
        const plan     = PLANS[activePlan];
        const cycle    = DISCOUNTS[activeCycle];
        const basePrice = plan.price;
        const discAmt   = basePrice * cycle.pct;
        const total     = basePrice - discAmt;

        document.getElementById('summaryPlan').textContent     = plan.label;
        document.getElementById('summaryPrice').textContent    = 'Rs ' + basePrice.toFixed(2);
        document.getElementById('summaryCycle').textContent    = capitalize(activeCycle);
        document.getElementById('summaryDiscount').textContent = cycle.pct > 0
            ? `-Rs ${discAmt.toFixed(2)} (${cycle.label})`
            : '–';
        document.getElementById('summaryTotal').textContent    = 'Rs ' + total.toFixed(2);
    }

    function capitalize(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

    /* ── Auto-fill lead ── */
    window.populateLead = function (select) {
        const opt = select.options[select.selectedIndex];
        document.getElementById('clientName').value    = opt.dataset.name    || '';
        document.getElementById('clientCompany').value = opt.dataset.company || '';
        document.getElementById('clientPhone').value   = opt.dataset.phone   || '';
    };

    /* ── Password generator ── */
    window.generatePassword = function () {
        const chars = 'ABCDEFGHJKMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789!@@#$';
        let pass = '';
        for (let i = 0; i < 10; i++) pass += chars[Math.floor(Math.random() * chars.length)];
        document.getElementById('tempPassword').value = pass;
    };

    /* ── Default start date ── */
    document.querySelector('input[name="StartDate"]').valueAsDate = new Date();

    /* ── Init summary ── */
    updateSummary();

})();
</script>
}
