@section Scripts {
    <script>
        // Page allowances management
        let selectedCount = 0;
        const totalPages = document.querySelectorAll('.page-checkbox').length;

        function updateSummary() {
            const checkboxes = document.querySelectorAll('.page-checkbox:checked');
            selectedCount = checkboxes.length;
            document.getElementById('pageCount').innerText = selectedCount;
        
            // Update storage usage (mock calculation: 5MB per page)
            const storageUsed = selectedCount * 5;
            const maxStorage = 500;
            const percentage = Math.min((storageUsed / maxStorage) * 100, 100);
            document.getElementById('storageUsed').innerText = storageUsed + ' MB';
            document.getElementById('storageBar').style.width = percentage + '%';
        }

        function toggleSection(sectionId, isChecked) {
            const checkboxes = document.querySelectorAll(`.page-checkbox[data-section="${sectionId}"]`);
            checkboxes.forEach(cb => cb.checked = isChecked);
            updateSummary();
        }

        function selectAllPages() {
            const checkboxes = document.querySelectorAll('.page-checkbox');
            checkboxes.forEach(cb => cb.checked = true);
            updateSummary();
        }

        function deselectAllPages() {
            const checkboxes = document.querySelectorAll('.page-checkbox');
            checkboxes.forEach(cb => cb.checked = false);
            updateSummary();
        }

        function loadBasicPlan() {
            deselectAllPages();
            // Basic plan pages
            const basicPages = ['dashboard_overview', 'leads_management', 'invoices', 'products', 'employees', 'company_settings'];
            basicPages.forEach(pageValue => {
                const checkbox = document.querySelector(`.page-checkbox[value="${pageValue}"]`);
                if (checkbox) checkbox.checked = true;
            });
            updateSummary();
            document.getElementById('tierSelect').value = 'basic';
        }

        function loadProfessionalPlan() {
            deselectAllPages();
            const professionalPages = [
                'dashboard_overview', 'analytics_reports', 'leads_management', 'opportunities', 'quotations',
                'invoices', 'payments', 'products', 'stock_management', 'employees', 'attendance',
                'general_ledger', 'expenses', 'company_settings', 'user_roles', 'support_tickets'
            ];
            professionalPages.forEach(pageValue => {
                const checkbox = document.querySelector(`.page-checkbox[value="${pageValue}"]`);
                if (checkbox) checkbox.checked = true;
            });
            updateSummary();
            document.getElementById('tierSelect').value = 'professional';
        }

        function loadEnterprisePlan() {
            selectAllPages();
            document.getElementById('tierSelect').value = 'enterprise';
        }

        function loadClientAllowances() {
            const clientId = document.getElementById('clientSelect').value;
            if (clientId) {
                // Simulate loading client-specific allowances
                loadProfessionalPlan();
                document.getElementById('tierSelect').value = '';
                showToast('Client allowances loaded', 'success');
            }
        }

        function loadTierAllowances() {
            const tier = document.getElementById('tierSelect').value;
            if (tier === 'basic') loadBasicPlan();
            else if (tier === 'professional') loadProfessionalPlan();
            else if (tier === 'enterprise') loadEnterprisePlan();
            else if (tier === 'custom') showToast('Custom mode enabled - select pages manually', 'info');
        }

        function resetToDefault() {
            if (confirm('Reset all allowances to default settings?')) {
                loadBasicPlan();
                document.getElementById('clientSelect').value = '';
                document.getElementById('tierSelect').value = 'basic';
                showToast('Reset to default settings', 'info');
            }
        }

        function saveAllowances() {
            const selectedPages = [];
            document.querySelectorAll('.page-checkbox:checked').forEach(cb => {
                selectedPages.push(cb.value);
            });
        
            console.log('Saving allowances:', selectedPages);
            showToast(`Saved ${selectedPages.length} page allowances successfully!`, 'success');
        
            // Here you would submit via AJAX or form post
            // document.getElementById('pageAllowancesForm').submit();
        }

        function showToast(message, type = 'success') {
            // Simple toast notification
            const toast = document.createElement('div');
            toast.className = `fixed bottom-4 right-4 z-50 px-4 py-3 rounded-lg text-white text-sm ${type === 'success' ? 'bg-green-600' : 'bg-blue-600'} shadow-lg transition-all duration-300 transform translate-y-0`;
            toast.innerText = message;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Attach event listeners to all checkboxes
        document.querySelectorAll('.page-checkbox').forEach(cb => {
            cb.addEventListener('change', updateSummary);
        });

        // Initial update
        updateSummary();
    </script>
}