@using Client_On_Boarding.DTO
@model ClientLeadVM
@{
    ViewData["Title"] = "Client Leads";
}

@* ── Page Header ── *@
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-semibold text-gray-800">Client Leads</h1>
        <p class="text-sm text-gray-500 mt-0.5">Manage and track all incoming client leads</p>
    </div>
    <a asp-action="CreateClientLead" asp-controller="Client"
       class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2.5 rounded-lg transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-white" viewBox="0 0 24 24">
            <path d="M18 2c2.206 0 4 1.794 4 4v12c0 2.206-1.794 4-4 4H6c-2.206 0-4-1.794-4-4V6c0-2.206 1.794-4 4-4zm0-2H6a6 6 0 0 0-6 6v12a6 6 0 0 0 6 6h12a6 6 0 0 0 6-6V6a6 6 0 0 0-6-6z" />
            <path d="M12 18a1 1 0 0 1-1-1V7a1 1 0 0 1 2 0v10a1 1 0 0 1-1 1z" />
            <path d="M6 12a1 1 0 0 1 1-1h10a1 1 0 0 1 0 2H7a1 1 0 0 1-1-1z" />
        </svg>
        Add Client Lead
    </a>
</div>

@* ── Summary Cards ── *@
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
    <div class="bg-blue-50 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Total Leads</p>
        <p class="text-2xl font-semibold text-gray-800">@Model.ClientLeads?.ToList().Count()</p>
        <span class="inline-block mt-1.5 text-xs font-medium bg-blue-100 text-blue-700 px-2 py-0.5 rounded">All time</span>
    </div>
    <div class="bg-blue-50 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">New This Month</p>
        <p class="text-2xl font-semibold text-gray-800">@Model.ClientLeads?.Count(x => x.CreateDate.HasValue && x.CreateDate.Value.Month == DateTime.Now.Month && x.CreateDate.Value.Year == DateTime.Now.Year)</p>
        <span class="inline-block mt-1.5 text-xs font-medium bg-green-100 text-green-700 px-2 py-0.5 rounded">This month</span>
    </div>
    <div class="bg-blue-50 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">In Progress</p>
        <p class="text-2xl font-semibold text-gray-800" id="card-inprogress">–</p>
        <span class="inline-block mt-1.5 text-xs font-medium bg-amber-100 text-amber-700 px-2 py-0.5 rounded">Needs follow-up</span>
    </div>
    <div class="bg-blue-50 rounded-xl p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Converted</p>
        <p class="text-2xl font-semibold text-gray-800" id="card-converted">–</p>
        <span class="inline-block mt-1.5 text-xs font-medium bg-green-100 text-green-700 px-2 py-0.5 rounded">Converted</span>
    </div>
</div>

@* ── Filters & Search ── *@
<div class="bg-white border border-gray-200 rounded-xl mb-4">
    <div class="flex flex-wrap items-center gap-3 px-5 py-3 border-b border-gray-100">

     
        <div class="flex items-center flex-1 min-w-[200px] bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 gap-2 focus-within:border-blue-400 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192.904 192.904" class="w-4 h-4 fill-gray-400 flex-shrink-0">
                <path d="m190.707 180.101-47.078-47.077c11.702-14.072 18.752-32.142 18.752-51.831C162.381 36.423 125.959 0 81.191 0 36.422 0 0 36.423 0 81.193c0 44.767 36.422 81.187 81.191 81.187 19.688 0 37.759-7.049 51.831-18.751l47.079 47.078a7.474 7.474 0 0 0 5.303 2.197 7.498 7.498 0 0 0 5.303-12.803zM15 81.193C15 44.694 44.693 15 81.191 15c36.497 0 66.189 29.694 66.189 66.193 0 36.496-29.692 66.187-66.189 66.187C44.693 147.38 15 117.689 15 81.193z" />
            </svg>
            <input id="searchInput" type="text" placeholder="Search by name, email or company..."
                   class="bg-transparent text-sm text-gray-700 outline-none w-full placeholder-gray-400" />
        </div>

       
        <select id="filterStatus" class="text-sm bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-gray-700 outline-none focus:border-blue-400 transition-colors">
            <option value="">All Statuses</option>
            @foreach (var item in Model.StatusDropdown)
            {
                <option value="@item.Text">@item.Text</option>
            }
        </select>

        <select id="filterSource" class="text-sm bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-gray-700 outline-none focus:border-blue-400 transition-colors">
            <option value="">All Sources</option>
            @foreach (var item in Model.LeadSourceDropdown)
            {
                <option value="@item.Text">@item.Text</option>
            }
        </select>

     
        <select id="sortSelect" class="text-sm bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-gray-700 outline-none focus:border-blue-400 transition-colors">
            <option value="newest">Sort by: Newest</option>
            <option value="oldest">Sort by: Oldest</option>
            <option value="name">Sort by: Name</option>
            <option value="status">Sort by: Status</option>
        </select>
    </div>

    @* ── Table ── *@
    <div class="overflow-x-auto">
        <table class="min-w-full" id="leadsTable">
            <thead class="bg-gray-800 whitespace-nowrap">
                <tr>
                    <th class="p-4 text-left text-xs font-medium text-white">Client</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Company</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Contact</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Source</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Status</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Priority</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Added On</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Added By</th>
                    <th class="p-4 text-left text-xs font-medium text-white">Actions</th>
                </tr>
            </thead>
            <tbody id="leadsBody" class="whitespace-nowrap divide-y divide-gray-100">
                @foreach (var leads in Model.ClientLeads)
                {
                   
                        string fullName = leads.ClientName ?? "";
                        var words = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        string initials;
                        if (words.Length == 1)
                            initials = words[0].Length > 1
                                ? (words[0][0].ToString() + words[0][^1].ToString()).ToUpper()
                            : words[0][0].ToString().ToUpper();
                        else
                            initials = string.Join("", words.Select(w => w[0]).Take(2)).ToUpper();
                    
                    <tr class="lead-row even:bg-blue-50 hover:bg-blue-50 transition-colors"
                        data-name="@leads.ClientName?.ToLower()"
                        data-company="@leads.CompanyName?.ToLower()"
                        data-phone="@leads.PhoneNo?.ToLower()"
                        data-status="@leads.LeadStatus?.StatusName"
                        data-source="@leads.LeadSource?.LeadSourceName"
                        data-date="@(leads.CreateDate.HasValue ? leads.CreateDate.Value.ToString("yyyy-MM-dd") : "")">

                        <td class="p-4">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center text-xs font-semibold flex-shrink-0">@initials</div>
                                <div>
                                    <p class="text-sm font-medium text-gray-800">@leads.ClientName</p>
                                </div>
                            </div>
                        </td>
                        <td class="p-4 text-sm text-gray-600">@leads.CompanyName</td>
                        <td class="p-4 text-sm text-gray-600">@leads.PhoneNo</td>
                        <td class="p-4">
                            <span class="text-xs font-medium bg-purple-100 text-purple-700 px-2.5 py-0.5 rounded-full">@leads.LeadSource?.LeadSourceName</span>
                        </td>
                        <td class="p-4">
                            <span class="text-xs font-medium bg-amber-100 text-amber-700 px-2.5 py-0.5 rounded-full">@leads.LeadStatus?.StatusName</span>
                        </td>
                        <td class="p-4">
                            <span class="text-xs font-medium bg-amber-100 text-amber-700 px-2.5 py-0.5 rounded-full">@leads.Priority?.PriorityName</span>
                        </td>
                        <td class="p-4 text-sm text-gray-500">@leads.CreateDate?.ToString("dd-MMM-yyyy")</td>
                        <td class="p-4">
                            <div class="flex items-center gap-2">
                                <div class="w-6 h-6 rounded-full bg-gray-200 flex items-center justify-center text-xs font-semibold text-gray-600">JD</div>
                                <span class="text-sm text-gray-600">Unknown-User</span>
                            </div>
                        </td>
                        <td class="p-4">
                            <div class="flex items-center gap-2">
                                <button title="View" class="text-gray-400 hover:text-blue-600 transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 511.999 511.999">
                                        <path d="M508.745 246.041c-4.574-6.257-113.557-153.206-252.748-153.206C127.513 92.835 18.573 239.784 14 246.041a19.995 19.995 0 0 0 0 19.917c4.573 6.257 113.557 153.206 252.997 153.206 139.44 0 248.425-146.949 252.997-153.206a19.998 19.998 0 0 0-.249-19.917zM255.997 379.164c-102.529 0-191.33-97.533-217.617-123.165C64.667 229.869 153.468 132.835 255.997 132.835c102.524 0 191.319 97.525 217.617 123.164-26.285 25.632-115.08 123.165-217.617 123.165z" />
                                        <path d="M255.997 172.165c-46.215 0-83.833 37.618-83.833 83.833s37.618 83.833 83.833 83.833 83.833-37.618 83.833-83.833-37.618-83.833-83.833-83.833zm0 127.666c-24.291 0-43.833-19.542-43.833-43.833s19.542-43.833 43.833-43.833 43.833 19.542 43.833 43.833-19.542 43.833-43.833 43.833z" />
                                    </svg>
                                </button>
                                <button title="Edit" class="text-gray-400 hover:text-blue-600 transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 348.882 348.882">
                                        <path d="m333.988 11.758-.42-.383A43.363 43.363 0 0 0 304.258 0a43.579 43.579 0 0 0-32.104 14.153L116.803 184.231a14.993 14.993 0 0 0-3.154 5.37l-18.267 54.762c-2.112 6.331-1.052 13.333 2.835 18.729 3.918 5.438 10.23 8.685 16.886 8.685h.001c2.879 0 5.693-.592 8.362-1.76l52.89-23.138a14.985 14.985 0 0 0 5.063-3.626L336.771 73.176c16.166-17.697 14.919-45.247-2.783-61.418zM130.381 234.247l10.719-32.134.904-.99 20.316 18.556-.904.99-31.035 13.578zm184.24-181.304L182.553 197.53l-20.316-18.556L294.305 34.386c2.583-2.828 6.118-4.386 9.954-4.386 3.365 0 6.588 1.252 9.082 3.53l.419.383c5.484 5.009 5.87 13.546.861 19.03z" />
                                        <path d="M303.85 138.388c-8.284 0-15 6.716-15 15v127.347c0 21.034-17.113 38.147-38.147 38.147H68.904c-21.035 0-38.147-17.113-38.147-38.147V100.413c0-21.034 17.113-38.147 38.147-38.147h131.587c8.284 0 15-6.716 15-15s-6.716-15-15-15H68.904C31.327 32.266.757 62.837.757 100.413v180.321c0 37.576 30.571 68.147 68.147 68.147h181.798c37.576 0 68.147-30.571 68.147-68.147V153.388c.001-8.284-6.715-15-14.999-15z" />
                                    </svg>
                                </button>
                                <button title="Delete" class="text-gray-400 hover:text-red-500 transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                                        <path d="M19 7a1 1 0 0 0-1 1v11.191A1.92 1.92 0 0 1 15.99 21H8.01A1.92 1.92 0 0 1 6 19.191V8a1 1 0 0 0-2 0v11.191A3.918 3.918 0 0 0 8.01 23h7.98A3.918 3.918 0 0 0 20 19.191V8a1 1 0 0 0-1-1Zm1-3h-4V2a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v2H4a1 1 0 0 0 0 2h16a1 1 0 0 0 0-2ZM10 4V3h4v1Z" />
                                        <path d="M11 17v-7a1 1 0 0 0-2 0v7a1 1 0 0 0 2 0Zm4 0v-7a1 1 0 0 0-2 0v7a1 1 0 0 0 2 0Z" />
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

      
        <div id="emptyState" class="hidden py-16 text-center text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-3 w-10 h-10 fill-gray-300" viewBox="0 0 192.904 192.904">
                <path d="m190.707 180.101-47.078-47.077c11.702-14.072 18.752-32.142 18.752-51.831C162.381 36.423 125.959 0 81.191 0 36.422 0 0 36.423 0 81.193c0 44.767 36.422 81.187 81.191 81.187 19.688 0 37.759-7.049 51.831-18.751l47.079 47.078a7.474 7.474 0 0 0 5.303 2.197 7.498 7.498 0 0 0 5.303-12.803zM15 81.193C15 44.694 44.693 15 81.191 15c36.497 0 66.189 29.694 66.189 66.193 0 36.496-29.692 66.187-66.189 66.187C44.693 147.38 15 117.689 15 81.193z" />
            </svg>
            <p class="text-sm font-medium">No leads match your filters</p>
            <p class="text-xs mt-1">Try adjusting your search or filter criteria</p>
        </div>
    </div>

    @* ── Pagination ── *@
    <div class="flex flex-wrap items-center justify-between gap-4 px-5 py-4 border-t border-gray-100">
        <p class="text-sm text-gray-500" id="pagingInfo">Showing <span id="pagingRange" class="font-medium text-gray-700">–</span> of <span id="pagingTotal" class="font-medium text-gray-700">–</span> leads</p>
        <div class="flex items-center gap-1" id="pagingButtons"></div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const PAGE_SIZE = 10;
    let currentPage = 1;
    let filtered = [];       // array of <tr> elements currently passing filters

    /* ── Gather all rows once ── */
    const allRows = Array.from(document.querySelectorAll('#leadsBody .lead-row'));

    /* ── Controls ── */
    const searchInput  = document.getElementById('searchInput');
    const filterStatus = document.getElementById('filterStatus');
    const filterSource = document.getElementById('filterSource');
    const sortSelect   = document.getElementById('sortSelect');
    const emptyState   = document.getElementById('emptyState');
    const pagingInfo   = document.getElementById('pagingInfo');
    const pagingRange  = document.getElementById('pagingRange');
    const pagingTotal  = document.getElementById('pagingTotal');
    const pagingBtns   = document.getElementById('pagingButtons');

    /* ── Event listeners ── */
    searchInput .addEventListener('input',  () => { currentPage = 1; apply(); });
    filterStatus.addEventListener('change', () => { currentPage = 1; apply(); });
    filterSource.addEventListener('change', () => { currentPage = 1; apply(); });
    sortSelect  .addEventListener('change', () => { currentPage = 1; apply(); });

    function apply() {
        const q      = searchInput.value.trim().toLowerCase();
        const status = filterStatus.value;
        const source = filterSource.value;
        const sort   = sortSelect.value;

        /* 1. Filter */
        filtered = allRows.filter(row => {
            const matchSearch = !q ||
                row.dataset.name   .includes(q) ||
                row.dataset.company.includes(q) ||
                row.dataset.phone  .includes(q);

            const matchStatus = !status || row.dataset.status === status;
            const matchSource = !source || row.dataset.source === source;

            return matchSearch && matchStatus && matchSource;
        });

        /* 2. Sort */
        filtered.sort((a, b) => {
            switch (sort) {
                case 'oldest':
                    return (a.dataset.date || '').localeCompare(b.dataset.date || '');
                case 'newest':
                    return (b.dataset.date || '').localeCompare(a.dataset.date || '');
                case 'name':
                    return (a.dataset.name || '').localeCompare(b.dataset.name || '');
                case 'status':
                    return (a.dataset.status || '').localeCompare(b.dataset.status || '');
                default:
                    return 0;
            }
        });

        /* 3. Paginate */
        renderPage();
    }

    function renderPage() {
        const total    = filtered.length;
        const lastPage = Math.max(1, Math.ceil(total / PAGE_SIZE));
        currentPage    = Math.min(currentPage, lastPage);

        const start = (currentPage - 1) * PAGE_SIZE;          // 0-based
        const end   = Math.min(start + PAGE_SIZE, total);      // exclusive

        /* Hide all, then show page slice in correct DOM order */
        allRows.forEach(r => r.style.display = 'none');
        filtered.slice(start, end).forEach(r => r.style.display = '');

        /* Re-apply even/odd striping to visible rows */
        filtered.slice(start, end).forEach((r, i) => {
            r.classList.toggle('bg-blue-50', i % 2 === 1);
            r.classList.toggle('even:bg-blue-50', false);   // remove Tailwind even: variant reliance
        });

        /* Empty state */
        emptyState.classList.toggle('hidden', total > 0);
        document.getElementById('leadsTable').classList.toggle('hidden', total === 0);

        /* Paging info */
        pagingRange.textContent = total === 0 ? '0' : `${start + 1}–${end}`;
        pagingTotal.textContent = total;

        /* Paging buttons */
        renderPagingButtons(lastPage);
    }

    function renderPagingButtons(lastPage) {
        pagingBtns.innerHTML = '';

        const btn = (label, page, disabled, active) => {
            const el = document.createElement('button');
            el.textContent = label;
            el.className = [
                'px-3 py-1.5 text-sm border rounded-lg transition-colors',
                active   ? 'bg-blue-600 text-white border-blue-600'
                         : 'text-gray-600 border-gray-200 hover:bg-gray-50',
                disabled ? 'opacity-40 cursor-not-allowed' : ''
            ].join(' ');
            if (!disabled) el.addEventListener('click', () => { currentPage = page; renderPage(); });
            return el;
        };

        pagingBtns.appendChild(btn('Previous', currentPage - 1, currentPage === 1, false));

        /* Window: always show first, last, current ±1, with ellipsis */
        const pages = getPageNumbers(currentPage, lastPage);
        let prev = null;
        pages.forEach(p => {
            if (prev !== null && p - prev > 1) {
                const dots = document.createElement('span');
                dots.textContent = '...';
                dots.className = 'px-2 text-gray-400 text-sm';
                pagingBtns.appendChild(dots);
            }
            pagingBtns.appendChild(btn(p, p, false, p === currentPage));
            prev = p;
        });

        pagingBtns.appendChild(btn('Next', currentPage + 1, currentPage === lastPage, false));
    }

    function getPageNumbers(current, last) {
        if (last <= 7) return Array.from({ length: last }, (_, i) => i + 1);
        const set = new Set([1, last, current, current - 1, current + 1].filter(p => p >= 1 && p <= last));
        return Array.from(set).sort((a, b) => a - b);
    }

    /* ── Initial render ── */
    apply();
})();
</script>
}
